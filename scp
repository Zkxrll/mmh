local function buildSkinRows(weaponName)
    SHdr.Text=weaponName:upper()
    for _,c in ipairs(SList:GetChildren()) do
        if c:IsA("TextButton") or (c:IsA("Frame") and c~=SPlaceholder) then c:Destroy() end
    end
    SPlaceholder.Visible=false
    local skins=WeaponSkins[weaponName] or {};local search=SSearch.Text:lower();local order=1
    for _,sm in ipairs(skins) do
        if search=="" or sm.Name:lower():find(search,1,true) then
            local isApplied=(State.pendingApply[weaponName]==sm)
            local hasAnims=next(getSkinSlots(toKey(weaponName),toKey(sm.Name)))~=nil

            local row=inst("TextButton",{Size=UDim2.new(1,0,0,42),
                BackgroundColor3=isApplied and T.SEL or T.CARD,
                BorderSizePixel=0,Text="",LayoutOrder=order},SList)
            corner(row,7)
            stroke(row,isApplied and T.SELBRD or T.BORDER,isApplied and 1 or 1)

            inst("TextLabel",{Size=UDim2.new(1,-70,0,20),Position=UDim2.new(0,12,0,isApplied and 5 or 11),
                BackgroundTransparency=1,Text=sm.Name,Font=Enum.Font.GothamSemibold,TextSize=12,
                TextColor3=isApplied and Color3.fromRGB(170,185,255) or T.PRI,
                TextXAlignment=Enum.TextXAlignment.Left,TextTruncate=Enum.TextTruncate.AtEnd},row)

            if hasAnims and isApplied then
                inst("TextLabel",{Size=UDim2.new(1,-70,0,12),Position=UDim2.new(0,12,0,26),
                    BackgroundTransparency=1,Text="custom animations",Font=Enum.Font.Gotham,TextSize=9,
                    TextColor3=T.PURPLE,TextXAlignment=Enum.TextXAlignment.Left},row)
            elseif hasAnims then
                inst("TextLabel",{Size=UDim2.new(1,-70,0,12),Position=UDim2.new(0,12,0,24),
                    BackgroundTransparency=1,Text="custom animations",Font=Enum.Font.Gotham,TextSize=9,
                    TextColor3=T.MUT,TextXAlignment=Enum.TextXAlignment.Left},row)
            end

            local applyBtn=inst("TextButton",{Size=UDim2.new(0,52,0,26),Position=UDim2.new(1,-60,0.5,-13),
                BackgroundColor3=isApplied and T.GREEN or T.ACCENT,
                Text=isApplied and "On" or "Apply",Font=Enum.Font.GothamBold,TextSize=11,
                TextColor3=Color3.fromRGB(255,255,255),BorderSizePixel=0},row)
            corner(applyBtn,6)

            if isApplied then
                applyBtn.Text="On"
                applyBtn.MouseButton1Click:Connect(function()
                    State.pendingApply[weaponName]=nil;SkinEngine.revertOne(weaponName)
                    saveData(State.pendingApply,State.keybind)
                    AppliedLbl.Text="Reverted "..weaponName;AppliedLbl.TextColor3=T.YELLOW
                    task.delay(2.5,function() AppliedLbl.TextColor3=T.SEC end)
                    buildSkinRows(weaponName);buildWeaponList(WSearch.Text)
                end)
            end

            local function doApply()
                if not State.enabled then
                    PillLbl.Text="Enable first";PillLbl.TextColor3=T.YELLOW
                    task.delay(1.5,updateToggle);return
                end
                State.pendingApply[weaponName]=sm
                local vOk=SkinEngine.apply(sm,weaponName)
                saveData(State.pendingApply,State.keybind)
                if vOk then
                    AppliedLbl.Text=sm.Name.." → "..weaponName;AppliedLbl.TextColor3=T.GREEN
                else
                    AppliedLbl.Text="Queued — equip "..weaponName;AppliedLbl.TextColor3=T.YELLOW
                end
                task.delay(3.5,function() AppliedLbl.TextColor3=T.SEC end)
                buildSkinRows(weaponName);buildWeaponList(WSearch.Text)
            end

            if not isApplied then applyBtn.MouseButton1Click:Connect(doApply) end
            row.MouseButton1Click:Connect(function() if not isApplied then doApply() end end)

            local hoverCol = isApplied and T.SEL or T.CARD
            row.MouseEnter:Connect(function() tw(row,{BackgroundColor3=T.CARDH}) end)
            row.MouseLeave:Connect(function() tw(row,{BackgroundColor3=hoverCol}) end)
            order+=1
        end
    end
    if order==1 then SPlaceholder.Text='No results for "'..SSearch.Text..'"';SPlaceholder.Visible=true end
end
SSearch:GetPropertyChangedSignal("Text"):Connect(function() if State.selectedWeapon then buildSkinRows(State.selectedWeapon) end end)

local function buildWeaponList(filter)
    filter=(filter or ""):lower()
    for _,c in ipairs(WList:GetChildren()) do if c:IsA("TextButton") then c:Destroy() end end
    local order=1
    for _,wn in ipairs(WeaponList) do
        if filter=="" or wn:lower():find(filter,1,true) then
            local isSel=(State.selectedWeapon==wn)
            local hasApp=(State.pendingApply[wn]~=nil)
            local btn=inst("TextButton",{Name=wn,Size=UDim2.new(1,0,0,32),
                BackgroundColor3=isSel and T.SEL or T.BG,
                BorderSizePixel=0,Text="",LayoutOrder=order},WList)
            corner(btn,6)
            if isSel then stroke(btn,T.SELBRD,1) end

            local lbl=inst("TextLabel",{Size=UDim2.new(1,-12,1,0),Position=UDim2.new(0,10,0,0),
                BackgroundTransparency=1,
                Text=wn,Font=Enum.Font.GothamSemibold,TextSize=11,
                TextColor3=isSel and Color3.fromRGB(170,185,255) or (hasApp and T.GREEN or T.SEC),
                TextXAlignment=Enum.TextXAlignment.Left,TextTruncate=Enum.TextTruncate.AtEnd},btn)

            -- applied dot
            if hasApp then
                inst("Frame",{Size=UDim2.new(0,4,0,4),Position=UDim2.new(1,-10,0.5,-2),
                    BackgroundColor3=T.GREEN,BorderSizePixel=0},btn)
                    :GetPropertyChangedSignal("Parent"):Connect(function() end)
                local dot=btn:FindFirstChildWhichIsA("Frame")
                if dot then corner(dot,2) end
            end

            btn.MouseEnter:Connect(function() if not isSel then tw(btn,{BackgroundColor3=T.CARD}) end end)
            btn.MouseLeave:Connect(function() if not isSel then tw(btn,{BackgroundColor3=T.BG}) end end)
            btn.MouseButton1Click:Connect(function()
                State.selectedWeapon=wn;SSearch.Text=""
                buildWeaponList(WSearch.Text);buildSkinRows(wn)
            end)
            order+=1
        end
    end
end
