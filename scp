    TB.InputBegan:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 then startDrag(i.Position) end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseMovement then moveDrag(i.Position) end
    end)
    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 then endDrag() end
    end)
    -- Touch — use GuiObject.TouchPan to consume the gesture before camera sees it
    TB.TouchPan:Connect(function(_, totalTranslation, _, state)
        if state==Enum.UserInputState.Begin then
            sp=Root.Position; ds=Vector2.new(0,0)
        end
        Root.Position=UDim2.new(
            sp.X.Scale, sp.X.Offset + totalTranslation.X,
            sp.Y.Scale, sp.Y.Offset + totalTranslation.Y)
    end)
end

