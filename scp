local function selectCard(skinName, thumb)
    SelectedSkin = skinName
    PreviewImg.Image = thumb or ""
    PreviewNone.Visible = (not thumb or thumb == "")
    PreviewSkinName.Text = skinName
    PreviewWeaponLabel.Text = SelectedWeapon or ""
    -- Grey out equip button for WIP skins
    if NEEDS_VISUAL_OVERRIDE[skinName] then
        EquipBtn.Text = "Not Available"
        EquipBtn.BackgroundColor3 = T.MUT
        EngineBadge.Text = "⚠ Work in progress — coming soon"
        EngineBadge.TextColor3 = T.RED
    else
        EquipBtn.Text = "Equip Skin"
        EquipBtn.BackgroundColor3 = T.ACCENT
        if skinName == "Default" then
            EngineBadge.Text = ""
        elseif useHook(skinName) then
            EngineBadge.Text = "Engine: Hook (native)"
            EngineBadge.TextColor3 = T.GREEN
        else
            EngineBadge.Text = "Engine: Visual (weld)"
            EngineBadge.TextColor3 = T.YELLOW
        end
    end
    for sn, card in pairs(SkinCards) do
        local isEquipped = SelectedWeapon and EquippedSkins[SelectedWeapon] == sn
        if sn == skinName then
            tw(card, {BackgroundColor3 = T.SEL})
            local ring = card:FindFirstChild("_ring"); if ring then ring.Visible = true end
        elseif isEquipped then
            tw(card, {BackgroundColor3 = T.CARDSEL})
            local ring = card:FindFirstChild("_ring"); if ring then ring.Visible = false end
        else
            tw(card, {BackgroundColor3 = T.CARD})
            local ring = card:FindFirstChild("_ring"); if ring then ring.Visible = false end
        end
    end
end

local function buildSkinGrid(weaponName)
    for _, c in ipairs(SkinGrid:GetChildren()) do
        if c:IsA("ImageButton") or c:IsA("Frame") then c:Destroy() end
    end
    SkinCards = {}; SelectedSkin = nil
    MidTitle.Text = weaponName:upper()
    local skins   = SkinLists[weaponName] or {}
    local equipped = EquippedSkins[weaponName]
    for i, skinName in ipairs(skins) do
        local isEquipped = (equipped == skinName) or (skinName == "Default" and (not equipped or equipped == "Default"))
        local thumb = getThumbnail(skinName)
        local card = inst("ImageButton", {
            Size = UDim2.new(0, 128, 0, 158),
            BackgroundColor3 = isEquipped and T.CARDSEL or T.CARD,
            BorderSizePixel = 0, Image = "", LayoutOrder = i,
        }, SkinGrid)
        corner(card, 9); stroke(card, isEquipped and T.SELBRD or T.BORDER, 1)
        local imgFrame = inst("Frame", {
            Size = UDim2.new(1, -12, 0, 96), Position = UDim2.new(0, 6, 0, 6),
            BackgroundColor3 = T.BG, BorderSizePixel = 0,
        }, card); corner(imgFrame, 7)
        inst("ImageLabel", {
            Size = UDim2.new(0.9, 0, 0.9, 0), Position = UDim2.new(0.05, 0, 0.05, 0),
            BackgroundTransparency = 1, Image = thumb,
            ScaleType = Enum.ScaleType.Fit, BorderSizePixel = 0,
        }, imgFrame)
        if not thumb or thumb == "" then
            inst("TextLabel", {
                Size = UDim2.new(1, 0, 1, 0), BackgroundTransparency = 1,
                Text = "?", Font = Enum.Font.GothamBold, TextSize = 28,
                TextColor3 = T.MUT, TextXAlignment = Enum.TextXAlignment.Center,
            }, imgFrame)
        end
        inst("TextLabel", {
            Size = UDim2.new(1, -8, 0, 36), Position = UDim2.new(0, 4, 0, 106),
            BackgroundTransparency = 1, Text = skinName,
            Font = Enum.Font.GothamSemibold, TextSize = 10,
            TextColor3 = T.PRI, TextXAlignment = Enum.TextXAlignment.Center, TextWrapped = true,
        }, card)
        if isEquipped then
            local badge = inst("TextLabel", {
                Size = UDim2.new(0, 58, 0, 16), Position = UDim2.new(0, 4, 0, 4),
                BackgroundColor3 = T.GREEN, Text = "EQUIPPED",
                Font = Enum.Font.GothamBold, TextSize = 7,
                TextColor3 = Color3.fromRGB(255, 255, 255), BorderSizePixel = 0,
            }, card); corner(badge, 4)
        end
        if NEEDS_VISUAL_OVERRIDE[skinName] then
            local vbadge = inst("TextLabel", {
                Size = UDim2.new(0, 58, 0, 14), Position = UDim2.new(1, -62, 0, 4),
                BackgroundColor3 = T.RED, Text = "⚠ WIP",
                Font = Enum.Font.GothamBold, TextSize = 7,
                TextColor3 = Color3.fromRGB(255, 255, 255), BorderSizePixel = 0,
            }, card); corner(vbadge, 4)
        end
        local ring = inst("Frame", {
            Name = "_ring", Size = UDim2.new(1, 0, 1, 0),
            BackgroundTransparency = 1, BorderSizePixel = 0, Visible = false,
        }, card)
        stroke(ring, T.ACCENT, 2); corner(ring, 9)
        SkinCards[skinName] = card
        card.MouseEnter:Connect(function()
            if SelectedSkin ~= skinName then tw(card, {BackgroundColor3 = T.CARDH}) end
        end)
        card.MouseLeave:Connect(function()
            if SelectedSkin ~= skinName then
                local eq = (EquippedSkins[weaponName] == skinName) or (skinName == "Default" and not EquippedSkins[weaponName])
                tw(card, {BackgroundColor3 = eq and T.CARDSEL or T.CARD})
            end
        end)
        card.MouseButton1Click:Connect(function() selectCard(skinName, thumb) end)
    end
    local cur = EquippedSkins[weaponName]
    if cur and SkinCards[cur] then selectCard(cur, getThumbnail(cur))
    else selectCard("Default", getThumbnail("Default")) end
end

local function buildWeaponList(filter)
    filter = (filter or ""):lower()
    for _, c in ipairs(WList:GetChildren()) do
        if c:IsA("TextButton") then c:Destroy() end
    end
    local order = 1
    for _, wn in ipairs(WeaponList) do
        if filter == "" or wn:lower():find(filter, 1, true) then
            local isSel  = (SelectedWeapon == wn)
            local hasApp = (EquippedSkins[wn] and EquippedSkins[wn] ~= "Default")
            local btn = inst("TextButton", {
                Size = UDim2.new(1, 0, 0, 32),
                BackgroundColor3 = isSel and T.SEL or T.BG,
                BorderSizePixel = 0, Text = "", LayoutOrder = order,
            }, WList)
            corner(btn, 6)
            if isSel then stroke(btn, T.SELBRD, 1) end
            inst("TextLabel", {
                Size = UDim2.new(1, -16, 1, 0), Position = UDim2.new(0, 10, 0, 0),
                BackgroundTransparency = 1, Text = wn,
                Font = Enum.Font.GothamSemibold, TextSize = 11,
                TextColor3 = isSel and Color3.fromRGB(170, 185, 255) or (hasApp and T.GREEN or T.SEC),
                TextXAlignment = Enum.TextXAlignment.Left,
                TextTruncate = Enum.TextTruncate.AtEnd,
            }, btn)
            if hasApp then
                local d = inst("Frame", {
                    Size = UDim2.new(0, 4, 0, 4), Position = UDim2.new(1, -10, 0.5, -2),
                    BackgroundColor3 = T.GREEN, BorderSizePixel = 0,
                }, btn); corner(d, 2)
            end
            btn.MouseEnter:Connect(function() if not isSel then tw(btn, {BackgroundColor3 = T.CARD}) end end)
            btn.MouseLeave:Connect(function() if not isSel then tw(btn, {BackgroundColor3 = T.BG}) end end)
            btn.MouseButton1Click:Connect(function()
                SelectedWeapon = wn; buildSkinGrid(wn); buildWeaponList(WSearch.Text)
            end)
            order += 1
        end
    end
end
WSearch:GetPropertyChangedSignal("Text"):Connect(function() buildWeaponList(WSearch.Text) end)

