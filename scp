    local availableSkins = SkinLists[weaponName] or { "Default" }
    local currentSkin    = EquippedSkins[weaponName] or "Default"
    local targetSection  = (i <= halfPoint) and sections.SkinsLeft or sections.SkinsRight
    UI_Dropdowns[weaponName] = targetSection:Dropdown({
        Name     = weaponName,
        Options  = availableSkins,
        Default  = currentSkin,
        Callback = function(Option)
            local selected = type(Option) == "table" and Option[1] or Option
            applyEquippedSkin(weaponName, selected)
        end,
    })
end

-- Config tab
sections.Config:Header({ Name = "General Config" })

sections.Config:Keybind({
    Name    = "Toggle Menu Bind",
    Default = savedKeybind,
    Callback = function(key)
        MasterData.Settings.ToggleKey = key.Name
        saveMasterData()
        pcall(function() Window:SetKeybind(key) end)
        Window:Notify({
            Title       = "Keybind Saved",
            Description = "Menu toggle is now " .. key.Name,
            Lifetime    = 3,
        })
    end,
})

sections.Config:Button({
    Name = "Clear Current Loadout",
    Callback = function()
        for w in pairs(EquippedSkins) do
            applyEquippedSkin(w, "Default")
            if UI_Dropdowns[w] then
                pcall(function() UI_Dropdowns[w]:Set("Default") end)
            end
        end
        Window:Notify({
            Title       = "Loadout Cleared",
            Description = "Reverted current skins to Default.",
            Lifetime    = 3,
        })
    end,
})

-- Profiles tab
sections.Profiles:Header({ Name = "Presets" })

local ProfileNameInput = ""
sections.Profiles:Input({
    Name               = "Profile Name",
    Placeholder        = "Enter name to save...",
    AcceptedCharacters = "All",
    Callback = function(val)
        ProfileNameInput = val
    end,
})

local function getProfileList()
    local list = {}
    for k in pairs(MasterData.Profiles) do table.insert(list, k) end
    return list
end

local SelectedProfileAction = MasterData.CurrentProfile
local UI_ProfileDropdown = sections.Profiles:Dropdown({
    Name    = "Select Profile",
    Options = getProfileList(),
    Default = MasterData.CurrentProfile,
    Callback = function(val)
        SelectedProfileAction = type(val) == "table" and val[1] or val
    end,
})

sections.Profiles:Button({
    Name = "Save Current as Profile",
    Callback = function()
        local name = (ProfileNameInput ~= "") and ProfileNameInput or "Default"
        MasterData.Profiles[name] = {}
        for w, s in pairs(EquippedSkins) do
            MasterData.Profiles[name][w] = s
        end
        MasterData.CurrentProfile = name
        saveMasterData()
        pcall(function()
            UI_ProfileDropdown:SetOptions(getProfileList())
            UI_ProfileDropdown:Set(name)
        end)
        Window:Notify({
            Title       = "Profile Saved",
            Description = "Saved loadout to " .. name,
            Lifetime    = 3,
        })
    end,
})

sections.Profiles:Button({
    Name = "Load Selected Profile",
    Callback = function()
        local target = SelectedProfileAction
        if not MasterData.Profiles[target] then return end
        MasterData.CurrentProfile = target
        EquippedSkins = {}
        for w in pairs(SkinLists) do
            local savedSkin = MasterData.Profiles[target][w] or "Default"
            applyEquippedSkin(w, savedSkin)
            if UI_Dropdowns[w] then
                pcall(function() UI_Dropdowns[w]:Set(savedSkin) end)
            end
        end
        saveMasterData()
        Window:Notify({
            Title       = "Profile Loaded",
            Description = "Equipped preset: " .. target,
            Lifetime    = 3,
        })
    end,
})

sections.Profiles:Button({
    Name = "Delete Selected Profile",
    Callback = function()
        local target = SelectedProfileAction
        if target == "Default" then
            Window:Notify({
                Title       = "Error",
                Description = "Cannot delete Default profile.",
                Lifetime    = 3,
            })
            return
        end
        if MasterData.Profiles[target] then
            MasterData.Profiles[target] = nil
            if MasterData.CurrentProfile == target then
                MasterData.CurrentProfile = "Default"
            end
            saveMasterData()
            pcall(function()
                UI_ProfileDropdown:SetOptions(getProfileList())
                UI_ProfileDropdown:Set(MasterData.CurrentProfile)
            end)
            Window:Notify({
                Title       = "Profile Deleted",
                Description = target .. " has been removed.",
                Lifetime    = 3,
            })
        end
    end,
})

Window:Notify({
    Title       = "Ready",
    Description = "Script injected. Press " .. savedKeybind.Name .. " to toggle menu.",
    Lifetime    = 5,
})
