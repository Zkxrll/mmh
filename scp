local function inst(cls,props,par)
    local i=Instance.new(cls)
    for k,v in pairs(props) do i[k]=v end
    if par then i.Parent=par end
    return i
end
local function corner(p,r) inst("UICorner",{CornerRadius=UDim.new(0,r or 3)},p) end
