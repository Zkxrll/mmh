local _cosmeticCache = {}
local function getCosmeticData(name)
    if _cosmeticCache[name] ~= nil then return _cosmeticCache[name] end
    if not CosmeticLibrary or not CosmeticLibrary.Cosmetics then
        _cosmeticCache[name] = false; return nil
    end
    local base = CosmeticLibrary.Cosmetics[name]
    if not base then
        local nl = name:lower()
        for k, v in pairs(CosmeticLibrary.Cosmetics) do
            if type(k) == "string" and k:lower() == nl then base = v; break end
        end
    end
    if not base then _cosmeticCache[name] = false; return nil end
    local proxy = setmetatable({Name = name, Type = "Skin"}, {__index = base})
    _cosmeticCache[name] = proxy
    return proxy
end

local function useHook(skinName)
    -- Always use hook if in CosmeticLibrary (even SKIP_RC_NAME skins go through
    -- Engine A for weapon creation — we just skip setting RC_NAME for them)
    local data = getCosmeticData(skinName)
    return data ~= nil and data ~= false
end

if ClientViewModel then
    local _oldNew = ClientViewModel.new
    ClientViewModel.new = function(replicatedData, clientItem)
        pcall(function()
            local isLocal = false
            pcall(function()
                isLocal = clientItem.ClientFighter.Player == LocalPlayer
            end)
            if not isLocal then return end

            local weaponName = clientItem and clientItem.Name
            if not weaponName then return end
            local skinName = EquippedSkins[weaponName]
            if not skinName or skinName == "Default" then return end
            if not State.enabled then return end
            if not useHook(skinName) then return end

            local cosData = getCosmeticData(skinName)
            if not cosData then return end
            if not RC_DATA or not RC_SKIN then return end

            replicatedData[RC_DATA] = replicatedData[RC_DATA] or {}
            replicatedData[RC_DATA][RC_SKIN] = {
                Name                = skinName,
                Type                = "Skin",
                ItemName            = cosData.ItemName,
                Rarity              = cosData.Rarity,
                Image               = cosData.Image,
                ImageHighResolution = cosData.ImageHighResolution,
                ImageScale          = cosData.ImageScale,
                Description         = cosData.Description,
                IsMythical          = (cosData.Rarity == "Mythical") or nil,
            }
            -- Only set RC_NAME for skins whose viewmodel config is registered
            -- in the game's internal lookup. Setting it for unregistered skins
            -- causes the weapon to silently vanish from the loadout.
            if RC_NAME and not SKIP_RC_NAME[skinName] then
                replicatedData[RC_DATA][RC_NAME] = skinName
            end
        end)

        local vm = _oldNew(replicatedData, clientItem)
        task.defer(function()
            pcall(function() if vm and vm._UpdateWrap then vm:_UpdateWrap() end end)
        end)
        return vm
    end
end

