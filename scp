-- ── Namecall Hook ─────────────────────────────────────────────────────
task.spawn(function()
    if not (hookmetamethod and newcclosure and getnamecallmethod) then return end
    local old
    old=hookmetamethod(game,"__namecall",newcclosure(function(self,...)
        local m=getnamecallmethod()
        if m=="Kick" and self==LocalPlayer then return nil end
        
        -- Optimized check: Ensures we only interact with instances, preventing crashes
        if m=="FireServer" and typeof(self) == "Instance" and self.Name == "EquipCosmetic" then
            local a1,a2,a3=...
            pcall(function()
                local wn,ct,cn=a1,a2,a3; if not wn or not ct then return end
                local ts=tostring(ct):lower(); local iw=ts:find("wrap")~=nil
                if not cn or cn=="" or cn=="None" then
                    if lobbyCosmetics[wn] then
                        lobbyCosmetics[wn][tostring(ct)]=nil
                        if iw then lobbyCosmetics[wn].Wrap=nil end
                        if not next(lobbyCosmetics[wn]) then lobbyCosmetics[wn]=nil end
                    end
                else
                    if CosmeticLibrary and CosmeticLibrary.Cosmetics then
                        local base=CosmeticLibrary.Cosmetics[cn]
                        if base then
                            local cl={}; for k,v in pairs(base) do cl[k]=v end
                            cl.Name=cn; cl.Seed=math.random(1,1e6); if iw then cl.Type="Wrap" end
                            lobbyCosmetics[wn]=lobbyCosmetics[wn] or {}
                            lobbyCosmetics[wn][tostring(ct)]=cl
                            if iw then lobbyCosmetics[wn].Wrap=cl end
                        end
                    end
                end
            end)
        end
        return old(self,...)
    end))
end)

