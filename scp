            ec=UserInputService.InputEnded:Connect(function(i2) if i2.UserInputType==Enum.UserInputType.MouseButton1 or i2.UserInputType==Enum.UserInputType.Touch then tbEnd(); mc:Disconnect(); ec:Disconnect() end end)
        end
    end)
