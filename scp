-- ─── LIVE VIEWMODEL WATCHER ──────────────────────────────────────────────────
local hookedFP=nil

local function applyWhenReady(weapon,child)
    task.wait(0.4)
    if not child.Parent then return end
    local vi=VMAInstances[weapon]
    if vi then
        local equipKey=vi._equip_animation
        local equipTrack=equipKey and vi._animation_tracks and vi._animation_tracks[equipKey]
        if equipTrack then
            local waited=0
            while equipTrack.IsPlaying and waited<1.5 do task.wait(0.05);waited+=0.05 end
        end
    else
        task.wait(0.5)
    end
    if not child.Parent then return end
    local skin=State.pendingApply[weapon]
    if skin and State.enabled then
        local ok=fullApplySkin(skin,weapon,child)
        if ok then StatusBadge.Text="● "..weapon;StatusBadge.TextColor3=T.GREEN;buildWeaponList(WSearch.Text) end
    end
end

local function onNewViewModel(child)
    if not child:IsA("Model") or not child.Name:find(PlayerName,1,true) then return end
    local weapon=child.Name:match("^.+ %- (.+) %- .+$");if not weapon then return end
    if State.applyDebounce[weapon] then return end
    State.applyDebounce[weapon]=true
    VMAInstances[weapon]=nil;AnimOriginals[weapon]=nil;TrackCache[weapon]=nil;ActiveSkins[weapon]=nil
    task.spawn(function()
        applyWhenReady(weapon,child)
        State.applyDebounce[weapon]=nil
    end)
end

local function onFirstPerson(fp)
    if fp==hookedFP then return end;hookedFP=fp;FirstPerson=fp
    for _,c in ipairs(fp:GetChildren()) do task.spawn(onNewViewModel,c) end
    fp.ChildAdded:Connect(function(c) if State.enabled then task.spawn(onNewViewModel,c) end end)
end
local function onViewModels(vm)
    local fp=vm:FindFirstChild("FirstPerson");if fp then onFirstPerson(fp) end
    vm.ChildAdded:Connect(function(c) if c.Name=="FirstPerson" then onFirstPerson(c) end end)
end
local evm=workspace:FindFirstChild("ViewModels");if evm then onViewModels(evm) end
workspace.ChildAdded:Connect(function(c) if c.Name=="ViewModels" then onViewModels(c) end end)

task.spawn(function()
    while task.wait(2) do
        if not ScreenGui.Parent then break end
        local vm=workspace:FindFirstChild("ViewModels");local fp=vm and vm:FindFirstChild("FirstPerson")
        FirstPerson=fp
        if fp then
            if fp~=hookedFP then onFirstPerson(fp) end;SkinEngine.refreshAll()
            local n=0;for _,c in ipairs(fp:GetChildren()) do if c:IsA("Model") and c.Name:find(PlayerName,1,true) then n+=1 end end
            StatusBadge.Text=n>0 and ("● In match") or "● In match"
            StatusBadge.TextColor3=n>0 and T.GREEN or T.YELLOW
        else
            local q=0;for _ in pairs(State.pendingApply) do q+=1 end
            StatusBadge.Text=q>0 and ("● Lobby  "..q.." active") or "● Lobby"
            StatusBadge.TextColor3=q>0 and T.ACCENT or T.SEC
        end
    end
end)

