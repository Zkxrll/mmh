local _acbPatched = false

local function applyACBPatch()
    for _, s in ipairs(getrunningscripts()) do
        if s.Name:find("MiscellaneousController") then
            local env = getsenv(s)
            if not env or not env.task then continue end
            if _acbPatched then break end

            local t = {}
            for k, v in pairs(task) do t[k] = v end

            local _acbThreads = {}

            t.spawn = function(fn, ...)
                return task.spawn(function(...)
                    _acbThreads[coroutine.running()] = true
                    fn(...)
                end, ...)
            end

            t.defer = function(fn, ...)
                return task.defer(function(...)
                    _acbThreads[coroutine.running()] = true
                    fn(...)
                end, ...)
            end

            t.delay = function(n, fn, ...)
                return task.delay(n, function(...)
                    _acbThreads[coroutine.running()] = true
                    fn(...)
                end, ...)
            end

            t.wait = function(n, ...)
                local co = coroutine.running()
                -- Only kill waits from tagged ACB coroutines, never from require/scheduler
                if co and _acbThreads[co] then
                    _acbThreads[co] = nil
                    error("__stop", 0)
                end
                return task.wait(n, ...)
            end

            env.task = t
            _acbPatched = true
            break
        end
    end
end

-- Retry loop: keeps trying until MiscellaneousController is found
-- Eliminates the 1/3 race condition from injection timing
task.spawn(function()
    for attempt = 1, 60 do
        if _acbPatched then break end
        pcall(applyACBPatch)
        if not _acbPatched then
            task.wait(0.1)
        end
    end
end)

