local function toKey(n) return n:lower():gsub("[^%a%d]","") end
local function extractWeaponType(name)
    return name:match("^.+ %- (.+) %- .+$") or name
end
local function getSkinSlots(wk, sk)
    if not AnimLibInfo then return {} end
    local res, prefix = {}, wk.."_"..sk.."_"
    for k,d in pairs(AnimLibInfo) do
        if type(k)=="string" and k:sub(1,#prefix)==prefix then
            local slot=k:sub(#prefix+1)
            if d and d.AnimationID then res[slot]=d.AnimationID end
        end
    end
    return res
end

-- ─── PERSISTENCE ─────────────────────────────────────────────────────────────
local SAVE_FILE = "rivals_skinchanger.json"

local function saveData(pendingApply, keybind)
    local data = {skins={}, keybind=tostring(keybind)}
    for w, sm in pairs(pendingApply) do data.skins[w] = sm.Name end
    pcall(function() writefile(SAVE_FILE, HttpService:JSONEncode(data)) end)
end

local function loadData()
    local ok, content = pcall(function() return readfile(SAVE_FILE) end)
    if not ok or not content or content=="" then return {}, Enum.KeyCode.RightAlt end
    local ok2, data = pcall(function() return HttpService:JSONDecode(content) end)
    if not ok2 or type(data)~="table" then return {}, Enum.KeyCode.RightAlt end
    local kb = Enum.KeyCode.RightAlt
    if data.keybind then
        pcall(function() kb = Enum.KeyCode[data.keybind] end)
    end
    return data.skins or {}, kb
end

-- ─── ANIMATION ENGINE ────────────────────────────────────────────────────────
local VMAInstances  = {}
local ActiveSkins   = {}
local AnimOriginals = {}
local TrackCache    = {}

local function getOrLoadTrack(wType, slotNorm, animId, vmaInst)
    TrackCache[wType] = TrackCache[wType] or {}
    local cached = TrackCache[wType][slotNorm]
    if cached then return cached end
    local animator
    pcall(function()
        animator = vmaInst.ClientViewModel.Model:FindFirstChildWhichIsA("Animator",true)
    end)
    if not animator then return nil end
    local anim = Instance.new("Animation")
    anim.AnimationId = animId
    local ok, track = pcall(function() return animator:LoadAnimation(anim) end)
    if ok and track then TrackCache[wType][slotNorm]=track; return track end
end

local function clearSkin(wType)
    local orig=AnimOriginals[wType]; local vmaInst=VMAInstances[wType]
    if orig and vmaInst then
        for slotKey, data in pairs(orig) do
            pcall(function()
                local cur=vmaInst._animation_tracks and vmaInst._animation_tracks[slotKey]
                if cur and cur.IsPlaying then cur:Stop(0) end
            end)
            if vmaInst._animation_tracks    and data.track   then vmaInst._animation_tracks[slotKey]=data.track     end
            if vmaInst._viewmodel_animations and data.animKey then vmaInst._viewmodel_animations[slotKey]=data.animKey end
        end
    end
    AnimOriginals[wType]=nil; ActiveSkins[wType]=nil; TrackCache[wType]=nil
end

if VMA then
    local _oldLoad = VMA.LoadAnimations
    VMA.LoadAnimations = function(self, ...)
        local r = _oldLoad(self, ...)
        task.spawn(function()
            task.wait(0.25)
            local wType=""
            pcall(function() wType=extractWeaponType(self.ClientViewModel.Name) end)
            if wType=="" then return end
            VMAInstances[wType]=self; TrackCache[wType]=nil; AnimOriginals[wType]=nil
            local pending=State and State.pendingApply and State.pendingApply[wType]
            if pending and State.enabled then
                local wk,sk=toKey(wType),toKey(pending.Name)
                ActiveSkins[wType]={wk=wk,sk=sk,slots=getSkinSlots(wk,sk)}
            end
        end)
        return r
    end

    local _oldPlay = VMA.PlayAnimation
    VMA.PlayAnimation = function(self, animKey, ...)
        local wType=""
        pcall(function() wType=extractWeaponType(self.ClientViewModel.Name) end)
        if wType~="" and self._animation_tracks then
            local info=ActiveSkins[wType]
            if info then
                local slotNorm=toKey(animKey)
                local skinAnimId=info.slots[slotNorm]
                if skinAnimId then
                    local skinTrack=getOrLoadTrack(wType,slotNorm,skinAnimId,self)
                    if skinTrack then
                        AnimOriginals[wType]=AnimOriginals[wType] or {}
                        if not AnimOriginals[wType][animKey] then
                            AnimOriginals[wType][animKey]={
                                track=self._animation_tracks[animKey],
                                animKey=self._viewmodel_animations and self._viewmodel_animations[animKey],
                            }
                        end
                        self._animation_tracks[animKey]=skinTrack
                        if self._viewmodel_animations then
                            self._viewmodel_animations[animKey]=info.wk.."_"..info.sk.."_"..slotNorm
                        end
                    end
                end
            end
        end
        return _oldPlay(self, animKey, ...)
    end
end

