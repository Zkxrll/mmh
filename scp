local TAG        = "RSC3Clone"
local ARM_GROUPS = {["_fake"] = true, ["_right_arm"] = true, ["_left_arm"] = true}

-- Remap source group names → live group names where they differ
local GROUP_REMAP = {
    -- Keyvolver: numbered bullet groups → single live groups
    ["Bullets1"]       = "Bullets",
    ["Bullets2"]       = "Bullets",
    ["Bullets3"]       = "Bullets",
    ["Bullets4"]       = "Bullets",
    ["Bullets5"]       = "Bullets",
    ["Bullets6"]       = "Bullets",
    ["ReloadBullets1"] = "ReloadBullets",
    ["ReloadBullets2"] = "ReloadBullets",
    ["ReloadBullets3"] = "ReloadBullets",
    ["ReloadBullets4"] = "ReloadBullets",
    ["ReloadBullets5"] = "ReloadBullets",
    ["ReloadBullets6"] = "ReloadBullets",
    -- Desert Eagle: Slide → Hammer, Magazine → Chamber
    ["Slide"]          = "Hammer",
    ["Magazine"]       = "Chamber",
    -- Key Bow extra arms → Body
    ["TopArm"]         = "Body",
    ["BottomArm"]      = "Body",
}

local _anchorCache = {}
local SkinModelMap = {}
if ViewModels then
    for _, folder in ipairs(ViewModels:GetChildren()) do
        if folder:IsA("Folder") then
            for _, model in ipairs(folder:GetChildren()) do
                if model:IsA("Model") then
                    SkinModelMap[model.Name] = model
                end
            end
        end
    end
end

local function findAnchor(g)
    local key = g:GetFullName()
    if _anchorCache[key] then return _anchorCache[key] end
    local result
    for _, p in ipairs(g:GetChildren()) do
        if p:IsA("BasePart") and p.Name == g.Name .. "Primary" then
            result = p; break
        end
    end
    if not result then
        for _, p in ipairs(g:GetChildren()) do
            if p:IsA("BasePart") and not p:IsA("MeshPart") then
                result = p; break
            end
        end
    end
    _anchorCache[key] = result
    return result
end

local function removeClones(m)
    for _, d in ipairs(m:GetDescendants()) do
        if d:GetAttribute(TAG) then
            if d:IsA("BasePart") then pcall(function() d.Anchored = true end) end
            d:Destroy()
        end
    end
end

local function restoreOriginals(m)
    for _, d in ipairs(m:GetDescendants()) do
        if d:IsA("BasePart") and not d:GetAttribute(TAG) then
            local o = d:GetAttribute("OrigTrans")
            if o ~= nil then
                d.Transparency = o
                d.CastShadow   = true
                d:SetAttribute("OrigTrans", nil)
            end
        end
    end
end

local function applyVisualSkin(src, live)
    removeClones(live)
    restoreOriginals(live)
    local iv = live:FindFirstChild("ItemVisual")
    if not iv then return false end
    local any = false
    for _, sg in ipairs(src:GetChildren()) do
        if not sg:IsA("Model") then continue end
        if sg.Name == "_charm_attachment_model" then continue end
        if ARM_GROUPS[sg.Name] then continue end
        local sa = sg:FindFirstChild("Primary")
        if not sa then continue end
        -- Use GROUP_REMAP to find the correct live group
        local lgName = GROUP_REMAP[sg.Name] or sg.Name
        local lg = iv:FindFirstChild(lgName)
        if not lg or not lg:IsA("Model") then continue end
        local la = findAnchor(lg)
        if not la then continue end
        for _, p in ipairs(lg:GetChildren()) do
            if p:IsA("MeshPart") and not p:GetAttribute(TAG) then
                if p:GetAttribute("OrigTrans") == nil then
                    p:SetAttribute("OrigTrans", p.Transparency)
                end
                p.Transparency = 1
                p.CastShadow   = false
            end
        end
        for _, sp in ipairs(sg:GetDescendants()) do
            if not sp:IsA("BasePart") or sp.Name == "Primary" then continue end
            local skip = false
            local par = sp.Parent
            while par and par ~= sg do
                if par.Name == "_charm_attachment_model" then skip = true; break end
                par = par.Parent
            end
            if skip then continue end
            local c = sp:Clone()
            c.CFrame     = la.CFrame * sa.CFrame:ToObjectSpace(sp.CFrame)
            c.Anchored   = false
            c.CanCollide = false
            c.CastShadow = false
            c:SetAttribute(TAG, true)
            c.Parent = lg
            local w  = Instance.new("WeldConstraint")
            w.Part0  = la
            w.Part1  = c
            w.Parent = c
        end
        any = true
    end
    return any
end

-- ─── ENGINE B SUPPORT ─────────────────────────────────────────────────────────
local FirstPerson = nil

local function findLiveModel(weaponType)
    if not FirstPerson then return nil end
    local pat = PlayerName .. " - " .. weaponType
    for _, c in ipairs(FirstPerson:GetChildren()) do
        if c:IsA("Model") and c.Name:find(pat, 1, true) then return c end
    end
end

local function hasClones(m)
    for _, d in ipairs(m:GetDescendants()) do
        if d:GetAttribute(TAG) then return true end
    end
    return false
end

local function applyVisualNow(skinName, weaponType)
    local src = SkinModelMap[skinName]
    if not src then return false end
    local live = findLiveModel(weaponType)
    if not live then return false end
    return applyVisualSkin(src, live)
end

local function revertVisual(weaponType)
    local live = findLiveModel(weaponType)
    if live then
        removeClones(live)
        restoreOriginals(live)
    end
    for key in pairs(_anchorCache) do
        if key:find(weaponType, 1, true) then _anchorCache[key] = nil end
    end
end

local _visualHooks = {}

local function hookVisualForWeapon(weaponType, skinName)
    if _visualHooks[weaponType] then
        _visualHooks[weaponType]:Disconnect()
        _visualHooks[weaponType] = nil
    end
    if not skinName or skinName == "Default" then return end

    local function tryApply(child)
        if not child:IsA("Model") then return end
        local pat = PlayerName .. " - " .. weaponType
        if not child.Name:find(pat, 1, true) then return end
        task.spawn(function()
            task.wait(0.5)
            if child.Parent and EquippedSkins[weaponType] == skinName and State.enabled then
                local src = SkinModelMap[skinName]
                if src then applyVisualSkin(src, child) end
            end
        end)
    end

    if FirstPerson then
        for _, c in ipairs(FirstPerson:GetChildren()) do tryApply(c) end
        _visualHooks[weaponType] = FirstPerson.ChildAdded:Connect(tryApply)
    end
end

local function refreshAllVisual()
    for weaponType, skinName in pairs(EquippedSkins) do
        if skinName and skinName ~= "Default" then
            -- Refresh Engine B skins (non-hook) and visual override skins
            if not useHook(skinName) or NEEDS_VISUAL_OVERRIDE[skinName] then
                local live = findLiveModel(weaponType)
                if live and not hasClones(live) then
                    local src = SkinModelMap[skinName]
                    if src then applyVisualSkin(src, live) end
                end
            end
        end
    end
end

-- ─── UNIFIED APPLY / REVERT ───────────────────────────────────────────────────
local function applyEquippedSkin(weaponType, skinName)
    if skinName == "Default" or skinName == nil then
        EquippedSkins[weaponType] = nil
        revertVisual(weaponType)
        if _visualHooks[weaponType] then
            _visualHooks[weaponType]:Disconnect()
            _visualHooks[weaponType] = nil
        end
    else
        EquippedSkins[weaponType] = skinName
        -- Engine B only, OR Engine A + Engine B visual overlay
        if not useHook(skinName) or NEEDS_VISUAL_OVERRIDE[skinName] then
            -- Try applying immediately if weapon is already live
            local src  = SkinModelMap[skinName]
            local live = findLiveModel(weaponType)
            if src and live then applyVisualSkin(src, live) end
            -- Also hook for future equips / respawns
            applyVisualNow(skinName, weaponType)
            hookVisualForWeapon(weaponType, skinName)
        end
    end
    saveData(EquippedSkins, State.keybind)
end

-- ─── THUMBNAIL ────────────────────────────────────────────────────────────────
local _thumbCache = {}
local function getThumbnail(name)
    if _thumbCache[name] ~= nil then return _thumbCache[name] end
    local img = ""
    local function tryFields(d)
        if not d then return end
        local v = d.ImageHighResolution or d.Image or d.Thumbnail
        if v and v ~= "" then img = v end
    end
    pcall(function()
        if ItemLibrary and ItemLibrary.ViewModels then
            tryFields(ItemLibrary.ViewModels[name])
        end
    end)
    if img == "" then
        pcall(function() tryFields(getCosmeticData(name)) end)
    end
    _thumbCache[name] = img
    return img
end

