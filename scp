        local target = SelectedProfileAction
        if target == "Default" then
            Window:Notify({ Title = "Error", Description = "Cannot delete Default profile.", Lifetime = 3 })
            return
        end
        if MasterData.Profiles[target] then
            MasterData.Profiles[target] = nil
            if MasterData.CurrentProfile == target then MasterData.CurrentProfile = "Default" end
            saveMasterData()
            
            pcall(function()
                UI_ProfileDropdown:SetOptions(getProfileList())
                UI_ProfileDropdown:Set(MasterData.CurrentProfile)
            end)
            
            Window:Notify({ Title = "Profile Deleted", Description = target .. " has been removed.", Lifetime = 3 })
        end
    end
})

Window:Notify({
    Title = "Ready",
    Description = "Script injected. Press " .. savedKeybind.Name .. " to toggle menu.",
    Lifetime = 5
})
