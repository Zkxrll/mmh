local function getRarityColor(sn)
    local d=buildCosmeticData(sn)
    if d and d.Rarity then return RARITY_COLORS[d.Rarity] or T.MUT end
    return T.MUT
end

local _tracked={}
local function track(o,p,k) table.insert(_tracked,{o=o,p=p,k=k}) end
local function applyStyle(name)
    local s=STYLES[name]; if not s then return end
    CurrentStyle=name
    for k,v in pairs(s) do T[k]=v end
    for _,t in ipairs(_tracked) do pcall(function() t.o[t.p]=T[t.k] end) end
end

