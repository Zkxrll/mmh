local WeaponSkins, WeaponList = {}, {}
local function buildWeaponSkins()
    if not ViewModels then return end
    for _,cf in ipairs(ViewModels:GetChildren()) do
        if cf:IsA("Folder") then
            for _,sm in ipairs(cf:GetChildren()) do
                if sm:IsA("Model") then
                    local w=WEAPON_MAP[sm.Name]
                    if w then WeaponSkins[w]=WeaponSkins[w] or {};table.insert(WeaponSkins[w],sm) end
                end
            end
        end
    end
    for _,s in pairs(WeaponSkins) do table.sort(s,function(a,b) return a.Name:lower()<b.Name:lower() end) end
    for w in pairs(WeaponSkins) do table.insert(WeaponList,w) end
    table.sort(WeaponList,function(a,b) return a:lower()<b:lower() end)
end
buildWeaponSkins()

