do
    local td,tds,tsp,moved=false,nil,nil,false
    local function tbMove(pos) if not td then return end; local d=pos-tds; if math.abs(d.X)+math.abs(d.Y)>6 then moved=true end; ToggleBtn.Position=UDim2.new(tsp.X.Scale,tsp.X.Offset+d.X,tsp.Y.Scale,tsp.Y.Offset+d.Y) end
