task.spawn(function()
    task.wait(0.5)
    print("[AC] Bypass starting...")

    -- KICK BLOCK via __namecall metamethod hook (community-standard approach)
    -- More reliable than hookfunction(LocalPlayer.Kick) because __namecall
    -- intercepts ALL colon-call paths, not just one function reference.
    task.spawn(function()
        if not hookmetamethod then
            -- Fallback: try hookfunction on Kick directly
            warn("[AC] hookmetamethod missing, trying hookfunction fallback")
            if not hookfunction or not newcclosure then
                warn("[AC] Kick block skipped: no hook functions available")
                return
            end
            local ok, fn = pcall(function() return LocalPlayer.Kick end)
            if ok and type(fn) == "function" then
                local oldkick
                oldkick = hookfunction(fn, newcclosure(function(self, ...)
                    if self == LocalPlayer then
                        warn("[AC] Kick blocked via hookfunction fallback")
                        return
                    end
                    return oldkick(self, ...)
                end))
                print("[AC] Kick blocked (hookfunction fallback)")
            end
            return
        end
        if not newcclosure or not getnamecallmethod then
            warn("[AC] Kick block skipped: missing newcclosure or getnamecallmethod")
            return
        end
        local old_namecall
        old_namecall = hookmetamethod(game, "__namecall", newcclosure(function(self, ...)
            local method = getnamecallmethod()

            -- Kick block
            if method == "Kick" and self == LocalPlayer then
                warn("[AC] Kick blocked via __namecall")
                return nil
            end

            if method == "FireServer" and _equipRemoteRef and self == _equipRemoteRef then
                local args = {...}
                pcall(function()
                    local weaponName   = args[1]
                    local cosmeticType = args[2]
                    local cosmeticName = args[3]
                    if weaponName and cosmeticType then
                        local typeKey = tostring(cosmeticType)
                        local isWrap  = typeKey:lower():find("wrap") ~= nil
                        if not cosmeticName or cosmeticName == "None" or cosmeticName == "" then
                            if lobbyCosmetics[weaponName] then
                                lobbyCosmetics[weaponName][typeKey] = nil
                                if isWrap then lobbyCosmetics[weaponName].Wrap = nil end
                                if not next(lobbyCosmetics[weaponName]) then
                                    lobbyCosmetics[weaponName] = nil
                                end
                            end
                        else
                            local cloned = cloneCosmetic(cosmeticName, cosmeticType)
                            if cloned then
                                lobbyCosmetics[weaponName] = lobbyCosmetics[weaponName] or {}
                                lobbyCosmetics[weaponName][typeKey] = cloned
                                if isWrap then
                                    cloned.Type = "Wrap"
                                    lobbyCosmetics[weaponName].Wrap = cloned
                                    print("[SC] Wrap stored:", weaponName, "->", cosmeticName)
                                end
                            end
                        end
                    end
                end)
            end

            return old_namecall(self, ...)
        end))
        print("[AC] Namecall hook active (Kick + EquipCosmetic tracking)")
    end)

    -- SCRIPTCONTEXT BLOCK
    -- Delayed 2s so CoreScripts have time to register their .Error connections.
    -- Without the delay, getconnections returns an empty table (0 connections found).
    task.spawn(function()
        task.wait(2)
        if not getconnections or not hookfunction or not newcclosure then
            warn("[AC] ScriptContext block skipped: missing funcs")
            return
        end
        local ok, ScriptContext = pcall(game.GetService, game, "ScriptContext")
        if not ok or not ScriptContext then warn("[AC] No ScriptContext"); return end
        local hooked = 0
        local ok2, conns = pcall(getconnections, ScriptContext.Error)
        if ok2 and type(conns) == "table" then
            for _, conn in ipairs(conns) do
                if pcall(function() conn:Disable() end) then
                    hooked += 1
                end
            end
        end
        pcall(function()
            hookfunction(ScriptContext.Error.Connect, newcclosure(function(...) return nil end))
        end)
        print("[AC] Blocked " .. hooked .. " ScriptContext.Error connections")
    end)

    -- LOGSERVICE BLOCK
    -- Same delay reason: MessageOut connections registered late by CoreScripts.
    task.spawn(function()
        task.wait(2)
        if not getconnections or not hookfunction or not newcclosure then
            warn("[AC] LogService block skipped: missing funcs")
            return
        end
        local ok, LogService = pcall(game.GetService, game, "LogService")
        if not ok or not LogService then return end
        local hooked = 0
        local ok2, conns = pcall(getconnections, LogService.MessageOut)
        if ok2 and type(conns) == "table" then
            for _, conn in pairs(conns) do
                if conn then
                    pcall(function() conn:Disable() end)
                    if conn.Function then
                        pcall(function()
                            hookfunction(conn.Function, newcclosure(function(...) end))
                        end)
                    end
                    hooked += 1
                end
            end
        end
        print("[AC] Blocked " .. hooked .. " LogService connections")
    end)
end)

