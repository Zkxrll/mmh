    local skins = WeaponSkins[w]
    if skins then
        for _,sm in ipairs(skins) do
            if sm.Name == skinName then State.pendingApply[w]=sm; break end
        end
    end
end

-- ─── VISUAL ENGINE ───────────────────────────────────────────────────────────
local TAG        = "RSkinClone"
local ARM_GROUPS = {["_fake"]=true,["_right_arm"]=true,["_left_arm"]=true}

local function findAnchor(g)
    for _,p in ipairs(g:GetChildren()) do
        if p:IsA("BasePart") and p.Name==g.Name.."Primary" then return p end
    end
    for _,p in ipairs(g:GetChildren()) do
        if p:IsA("BasePart") and not p:IsA("MeshPart") then return p end
    end
    for _,p in ipairs(g:GetChildren()) do
        if p:IsA("Model") then local a=findAnchor(p);if a then return a end end
    end
end
local function removeClones(m)
    for _,d in ipairs(m:GetDescendants()) do if d:GetAttribute(TAG) then d:Destroy() end end
end
local function restoreOriginals(m)
    for _,d in ipairs(m:GetDescendants()) do
        if d:IsA("BasePart") and not d:GetAttribute(TAG) then
            local o=d:GetAttribute("OrigTrans")
            if o~=nil then d.Transparency=o;d.CastShadow=true;d:SetAttribute("OrigTrans",nil) end
        end
    end
end
local function applyVisualSkin(src,live)
    removeClones(live); restoreOriginals(live)
    local iv=live:FindFirstChild("ItemVisual"); if not iv then return false end
    local liveBodyGroup=iv:FindFirstChild("Body")
    local liveBodyAnchor=liveBodyGroup and findAnchor(liveBodyGroup)
    if not liveBodyAnchor then return false end
    local any=false
    for _,sg in ipairs(src:GetChildren()) do
        if not sg:IsA("Model") or sg.Name=="_charm_attachment_model" or ARM_GROUPS[sg.Name] then continue end
        local sa=sg:FindFirstChild("Primary"); if not sa then continue end
        local lg=iv:FindFirstChild(sg.Name)
        local matched=lg and lg:IsA("Model")
        local la,parentGroup
        if matched then
            la=findAnchor(lg); if not la then continue end
            parentGroup=lg
            for _,p in ipairs(lg:GetChildren()) do
                if p:IsA("MeshPart") and not p:GetAttribute(TAG) then
                    if p:GetAttribute("OrigTrans")==nil then p:SetAttribute("OrigTrans",p.Transparency) end
                    p.Transparency=1;p.CastShadow=false
                end
            end
        else
            la=liveBodyAnchor;parentGroup=liveBodyGroup
        end
        for _,sp in ipairs(sg:GetDescendants()) do
            if not sp:IsA("BasePart") or sp.Name=="Primary" then continue end
            local skip=false; local par=sp.Parent
            while par and par~=sg do
                if par.Name=="_charm_attachment_model" then skip=true;break end; par=par.Parent
            end
            if skip then continue end
            local c=sp:Clone()
            c.CFrame=la.CFrame*sa.CFrame:ToObjectSpace(sp.CFrame)
            c.Anchored=false;c.CanCollide=false;c.CastShadow=false
            c:SetAttribute(TAG,true);c.Parent=parentGroup
            local w=Instance.new("WeldConstraint");w.Part0=la;w.Part1=c;w.Parent=c
        end
        any=true
    end
    return any
end
local function fullApplySkin(src,wType,live)
    local v=applyVisualSkin(src,live)
    local wk,sk=toKey(wType),toKey(src.Name)
    local slots=getSkinSlots(wk,sk)
    if next(slots) then ActiveSkins[wType]={wk=wk,sk=sk,slots=slots} end
    return v,next(slots) and 1 or 0
end
local function findLive(wn)
    if not FirstPerson then return end
    local pat=PlayerName.." - "..wn
    for _,c in ipairs(FirstPerson:GetChildren()) do
        if c:IsA("Model") and c.Name:find(pat,1,true) then return c end
    end
end
local function hasClones(m)
    for _,d in ipairs(m:GetDescendants()) do if d:GetAttribute(TAG) then return true end end
end
local function revertOne(w)
    local l=findLive(w);if l then removeClones(l);restoreOriginals(l) end; clearSkin(w)
end

local SkinEngine={}
function SkinEngine.apply(sm,wt)
    local l=findLive(wt);if l then return fullApplySkin(sm,wt,l) end;return false,0
end
function SkinEngine.refreshAll()
    if not State.enabled then return end
    for w,s in pairs(State.pendingApply) do
        local l=findLive(w)
        if l and not hasClones(l) then fullApplySkin(s,w,l) end
    end
end
