-- ── Logic ─────────────────────────────────────────────────────────────────────
local SelectedWeapon=nil; local SelectedSkin=nil; local SkinCards={}
-- Weapon list DOM cache: built once, subsequent calls just refresh colors
local _wListBuilt=false; local _wBtns={}

local function rebuildSummary()
    for _,c in ipairs(SummaryScroll:GetChildren()) do
        if not c:IsA("UIListLayout") then c:Destroy() end
    end
    local order=1; local any=false
    for w,s in pairs(EquippedSkins) do
        if s and s~="Default" then
            any=true
            local row=inst("Frame",{Size=UDim2.new(1,0,0,18),BackgroundColor3=T.CARD,BorderSizePixel=0,LayoutOrder=order},SummaryScroll)
            corner(row,2)
            inst("Frame",{Size=UDim2.new(0,2,1,0),BackgroundColor3=getRarityColor(s),BorderSizePixel=0},row)
            inst("UIPadding",{PaddingLeft=UDim.new(0,7),PaddingRight=UDim.new(0,5)},row)
            inst("TextLabel",{Size=UDim2.new(0.46,0,1,0),BackgroundTransparency=1,Text=w,Font=Enum.Font.GothamSemibold,TextSize=8,TextColor3=T.SEC,TextXAlignment=Enum.TextXAlignment.Left,TextTruncate=Enum.TextTruncate.AtEnd},row)
            inst("TextLabel",{Size=UDim2.new(0.54,0,1,0),Position=UDim2.new(0.46,0,0,0),BackgroundTransparency=1,Text=s,Font=Enum.Font.GothamSemibold,TextSize=8,TextColor3=getRarityColor(s),TextXAlignment=Enum.TextXAlignment.Right,TextTruncate=Enum.TextTruncate.AtEnd},row)
            order+=1
        end
    end
    if not any then
        inst("TextLabel",{Size=UDim2.new(1,0,0,20),BackgroundTransparency=1,Text="none active",Font=Enum.Font.Gotham,TextSize=9,TextColor3=T.MUT,TextXAlignment=Enum.TextXAlignment.Left,LayoutOrder=1},SummaryScroll)
    end
end

local function selectCard(skinName,thumb)
    SelectedSkin=skinName; PreviewImg.Image=thumb or ""; PreviewNone.Visible=(not thumb or thumb=="")
    PreviewSkinName.Text=skinName; PreviewWeaponLabel.Text=SelectedWeapon and SelectedWeapon:upper() or ""
    local d=buildCosmeticData(skinName)
    if d and d.Rarity then RarityBadge.Text=d.Rarity:upper(); RarityBadge.TextColor3=getRarityColor(skinName) else RarityBadge.Text="" end
    EquipBtn.Text="EQUIP SKIN"; EquipBtn.BackgroundColor3=T.ACCENT
    for sn,card in pairs(SkinCards) do
        local isEquipped=SelectedWeapon and EquippedSkins[SelectedWeapon]==sn
        if sn==skinName then
            tw(card,{BackgroundColor3=T.SEL}); local ring=card:FindFirstChild("_ring"); if ring then ring.Visible=true end
        elseif isEquipped then
            tw(card,{BackgroundColor3=T.CARDSEL}); local ring=card:FindFirstChild("_ring"); if ring then ring.Visible=false end
        else
            tw(card,{BackgroundColor3=T.CARD}); local ring=card:FindFirstChild("_ring"); if ring then ring.Visible=false end
        end
    end
end

local function buildSkinGrid(weaponName)
    for _,c in ipairs(SkinGrid:GetChildren()) do if c:IsA("ImageButton") or c:IsA("Frame") then c:Destroy() end end
    SkinCards={}; SelectedSkin=nil; MidTitle.Text=weaponName:upper()
    local skins=SkinLists[weaponName] or {}; local equipped=EquippedSkins[weaponName]
    for i,skinName in ipairs(skins) do
        local isEquipped=(equipped==skinName) or (skinName=="Default" and (not equipped or equipped=="Default"))
        local thumb=getThumbnail(skinName)
        local card=inst("ImageButton",{Size=UDim2.new(0,CARD_W,0,CARD_H),BackgroundColor3=isEquipped and T.CARDSEL or T.CARD,BorderSizePixel=0,Image="",LayoutOrder=i},SkinGrid)
        corner(card,3); stroke(card,isEquipped and T.SELBRD or T.BORDER,1)
        local imgH=math.floor(CARD_H*0.65)
        local imgFrame=inst("Frame",{Size=UDim2.new(1,-6,0,imgH),Position=UDim2.new(0,3,0,3),BackgroundColor3=T.BG,BorderSizePixel=0},card)
        corner(imgFrame,2)
        inst("ImageLabel",{Size=UDim2.new(0.9,0,0.9,0),Position=UDim2.new(0.05,0,0.05,0),BackgroundTransparency=1,Image=thumb,ScaleType=Enum.ScaleType.Fit,BorderSizePixel=0},imgFrame)
        if not thumb or thumb=="" then
            inst("TextLabel",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text="?",Font=Enum.Font.GothamBold,TextSize=22,TextColor3=T.MUT,TextXAlignment=Enum.TextXAlignment.Center},imgFrame)
        end
        inst("TextLabel",{Size=UDim2.new(1,-4,0,CARD_H-imgH-6),Position=UDim2.new(0,2,0,imgH+4),BackgroundTransparency=1,Text=skinName,Font=Enum.Font.GothamSemibold,TextSize=8,TextColor3=T.PRI,TextXAlignment=Enum.TextXAlignment.Center,TextWrapped=true},card)
        if isEquipped then
            local badge=inst("TextLabel",{Size=UDim2.new(0,40,0,11),Position=UDim2.new(0,3,0,3),BackgroundColor3=T.ACCENT,Text="ON",Font=Enum.Font.GothamBold,TextSize=6,TextColor3=Color3.fromRGB(6,8,10),BorderSizePixel=0},card)
            corner(badge,2)
        end
        if skinName~="Default" then
            local rdot=inst("Frame",{Size=UDim2.new(0,4,0,4),Position=UDim2.new(1,-7,0,4),BackgroundColor3=getRarityColor(skinName),BorderSizePixel=0},card)
            corner(rdot,2)
        end
        local ring=inst("Frame",{Name="_ring",Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,BorderSizePixel=0,Visible=false},card)
        stroke(ring,T.ACCENT,2); corner(ring,3); SkinCards[skinName]=card
        card.MouseEnter:Connect(function() if SelectedSkin~=skinName then tw(card,{BackgroundColor3=T.CARDH}) end end)
        card.MouseLeave:Connect(function()
            if SelectedSkin~=skinName then
                local eq=(EquippedSkins[weaponName]==skinName) or (skinName=="Default" and not EquippedSkins[weaponName])
                tw(card,{BackgroundColor3=eq and T.CARDSEL or T.CARD})
            end
        end)
        card.MouseButton1Click:Connect(function() selectCard(skinName,thumb) end)
    end
    local cur=EquippedSkins[weaponName]
    if cur and SkinCards[cur] then selectCard(cur,getThumbnail(cur)) else selectCard("Default",getThumbnail("Default")) end
end

-- FIX 3 continued: weapon list cached after first build so repeat calls
-- (on weapon select, equip, revert) only refresh colors instead of
-- recreating all 47 buttons — this is what caused the per-action freeze
local function buildWeaponList(filter)
    filter=(filter or ""):lower()
    if filter=="" and _wListBuilt then
        for wn,btn in pairs(_wBtns) do
            local isSel=(SelectedWeapon==wn)
            local hasApp=(EquippedSkins[wn] and EquippedSkins[wn]~="Default")
            local ac=btn:FindFirstChild("_accent"); local lb=btn:FindFirstChild("_label"); local dt=btn:FindFirstChild("_dot")
            btn.BackgroundColor3=isSel and T.SEL or Color3.fromRGB(0,0,0)
            btn.BackgroundTransparency=isSel and 0 or 1
            if ac then ac.BackgroundTransparency=isSel and 0 or 1 end
            if lb then lb.TextColor3=isSel and T.PRI or (hasApp and T.GREEN or T.SEC) end
            if dt then dt.Visible=hasApp end
        end
        return
    end
    for _,c in ipairs(WList:GetChildren()) do if c:IsA("TextButton") or c:IsA("Frame") then c:Destroy() end end
    _wBtns={}
    local order=1
    for _,wn in ipairs(WeaponList) do
        if filter=="" or wn:lower():find(filter,1,true) then
            local isSel=(SelectedWeapon==wn); local hasApp=(EquippedSkins[wn] and EquippedSkins[wn]~="Default")
            local btn=inst("TextButton",{Size=UDim2.new(1,0,0,24),BackgroundColor3=isSel and T.SEL or Color3.fromRGB(0,0,0),BackgroundTransparency=isSel and 0 or 1,BorderSizePixel=0,Text="",LayoutOrder=order},WList)
            corner(btn,2)
            inst("Frame",{Name="_accent",Size=UDim2.new(0,2,0.6,0),Position=UDim2.new(0,0,0.2,0),BackgroundColor3=T.ACCENT,BorderSizePixel=0,BackgroundTransparency=isSel and 0 or 1},btn)
            inst("TextLabel",{Name="_label",Size=UDim2.new(1,-18,1,0),Position=UDim2.new(0,8,0,0),BackgroundTransparency=1,Text=wn,Font=Enum.Font.GothamSemibold,TextSize=10,TextColor3=isSel and T.PRI or (hasApp and T.GREEN or T.SEC),TextXAlignment=Enum.TextXAlignment.Left,TextTruncate=Enum.TextTruncate.AtEnd},btn)
            local dt=inst("Frame",{Name="_dot",Size=UDim2.new(0,3,0,3),Position=UDim2.new(1,-8,0.5,-2),BackgroundColor3=T.GREEN,BorderSizePixel=0,Visible=hasApp},btn); corner(dt,1)
            btn.MouseEnter:Connect(function() if SelectedWeapon~=wn then tw(btn,{BackgroundColor3=T.CARD,BackgroundTransparency=0}) end end)
            btn.MouseLeave:Connect(function() if SelectedWeapon~=wn then tw(btn,{BackgroundColor3=T.CARD,BackgroundTransparency=1}) end end)
            btn.MouseButton1Click:Connect(function() SelectedWeapon=wn; buildSkinGrid(wn); buildWeaponList(WSearch.Text) end)
            if filter=="" then _wBtns[wn]=btn end
            order+=1
        end
    end
    if filter=="" then _wListBuilt=true end
end

