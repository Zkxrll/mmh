-- ── Require hook ──────────────────────────────────────────────────────────────
local originalRequire = require
local blockedScripts = {"LocalScript3","MiscellaneousController","LoadingScreen","ClientAlert"}
local function makeDummy()
    local dummy
    dummy = setmetatable({}, {
        __index    = function() return dummy end,
        __call     = function() return dummy end,
        __newindex = function() end,
    })
    return dummy
end
require = function(module)
    local moduleName = tostring(module)
    for _, name in ipairs(blockedScripts) do
        if moduleName:find(name) then
            print("[AC] Blocked require of", moduleName)
            return makeDummy()
        end
    end
    return originalRequire(module)
end
print("[AC] Require hook installed")

-- ── Persistence ───────────────────────────────────────────────────────────────
local SAVE_FILE = "rivals_sc_v4.json"

local function saveData(equippedSkins, keybind)
    pcall(function()
        writefile(SAVE_FILE, HttpService:JSONEncode({
            skins   = equippedSkins,
            keybind = tostring(keybind),
        }))
    end)
end

local function loadData()
    local ok, raw = pcall(readfile, SAVE_FILE)
    if not ok or not raw or raw == "" then return {}, Enum.KeyCode.RightAlt end
    local ok2, data = pcall(function() return HttpService:JSONDecode(raw) end)
    if not ok2 or type(data) ~= "table" then return {}, Enum.KeyCode.RightAlt end
    local kb = Enum.KeyCode.RightAlt
    pcall(function() if data.keybind then kb = Enum.KeyCode[data.keybind] end end)
    return data.skins or {}, kb
end

