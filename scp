    buildSkinGrid(SelectedWeapon); WSearch.Text = ""; buildWeaponList(""); rebuildSummary()
end)

ClearAllBtn.MouseButton1Click:Connect(function()
    for w in pairs(EquippedSkins) do applyEquippedSkin(w, "Default") end
    saveData(EquippedSkins, State.keybind)
    if SelectedWeapon then buildSkinGrid(SelectedWeapon) end
    WSearch.Text = ""; buildWeaponList(""); rebuildSummary()
    ClearAllBtn.Text = "Cleared ✓"; ClearAllBtn.TextColor3 = T.GREEN
    task.delay(1.5, function() ClearAllBtn.Text = "Clear All Skins"; ClearAllBtn.TextColor3 = T.RED end)
end)

KeybindBtn.MouseButton1Click:Connect(function()
    if State.rebinding then return end
    State.rebinding = true
    KeybindBtn.Text = "Press any key..."; KeybindBtn.TextColor3 = T.YELLOW
    tw(KeybindBtn, {BackgroundColor3 = Color3.fromRGB(40, 35, 10)})
    local conn
    conn = UserInputService.InputBegan:Connect(function(i, gpe)
        if gpe then return end
        if i.UserInputType == Enum.UserInputType.Keyboard then
            State.keybind = i.KeyCode
            KeybindBtn.Text = "Keybind: " .. tostring(i.KeyCode.Name)
            KeybindBtn.TextColor3 = T.ACCENT
            tw(KeybindBtn, {BackgroundColor3 = T.CARD})
            saveData(EquippedSkins, State.keybind)
            State.rebinding = false; conn:Disconnect()
        end
    end)
end)

UserInputService.InputBegan:Connect(function(i, gpe)
    if gpe or State.rebinding then return end
    if i.KeyCode == State.keybind then ScreenGui.Enabled = not ScreenGui.Enabled end
end)

-- ─── FIRSTPERSON WATCHER ──────────────────────────────────────────────────────
local hookedFP = nil

local function onFirstPerson(fp)
    if fp == hookedFP then return end
    hookedFP = fp; FirstPerson = fp
    for weaponType, skinName in pairs(EquippedSkins) do
        if skinName and skinName ~= "Default" then
            -- Hook visual for both pure Engine B skins and visual override skins
            if not useHook(skinName) or NEEDS_VISUAL_OVERRIDE[skinName] then
                hookVisualForWeapon(weaponType, skinName)
            end
        end
    end
end

local function onViewModels(vm)
    local fp = vm:FindFirstChild("FirstPerson")
    if fp then onFirstPerson(fp) end
    vm.ChildAdded:Connect(function(c)
        if c.Name == "FirstPerson" then onFirstPerson(c) end
    end)
end

local evm = workspace:FindFirstChild("ViewModels")
if evm then onViewModels(evm) end
workspace.ChildAdded:Connect(function(c)
    if c.Name == "ViewModels" then onViewModels(c) end
end)

task.spawn(function()
    while task.wait(2) do
        if not ScreenGui.Parent then break end
        local vm = workspace:FindFirstChild("ViewModels")
        local fp = vm and vm:FindFirstChild("FirstPerson")
        FirstPerson = fp
        if fp then
            if fp ~= hookedFP then onFirstPerson(fp) end
            refreshAllVisual()
        end
    end
end)

-- Restore saved skins on load
for weaponType, skinName in pairs(EquippedSkins) do
    if skinName and skinName ~= "Default" then
        if not useHook(skinName) or NEEDS_VISUAL_OVERRIDE[skinName] then
            hookVisualForWeapon(weaponType, skinName)
        end
    end
end

