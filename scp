-- ── Core Hook Functions ───────────────────────────────────────────────
local CosmeticLibrary, ItemLibrary, ReplicatedClass, DataController
local ClientItem, ClientViewModelModule, EnumLibrary
local _constructingWeapon = nil
local _hooksApplied       = false
local _cosmeticCache      = {}
local _cosmeticLookup     = nil
local _wrapDebounces      = {}
local _wdCache            = {} -- Memory leak fix: Deep cache for weapon data

local function _ensureLookup()
    if _cosmeticLookup or not CosmeticLibrary or not CosmeticLibrary.Cosmetics then return end
    _cosmeticLookup = {}
    for k in pairs(CosmeticLibrary.Cosmetics) do
        if type(k)=="string" then _cosmeticLookup[k:lower()]=k end
    end
end

local function buildCosmeticData(skinName)
    if _cosmeticCache[skinName] then return _cosmeticCache[skinName] end
    if not CosmeticLibrary or not CosmeticLibrary.Cosmetics then return nil end
    _ensureLookup()
    local key = (CosmeticLibrary.Cosmetics[skinName] and skinName) or (_cosmeticLookup and _cosmeticLookup[skinName:lower()])
    local base = key and CosmeticLibrary.Cosmetics[key]
    if not base then return nil end
    local d = {Name=skinName,Type="Skin",ItemName=base.ItemName,Rarity=base.Rarity,
        Image=base.Image,ImageHighResolution=base.ImageHighResolution,
        ImageScale=base.ImageScale,Description=base.Description,Seed=math.random(1,1e6)}
    if EnumLibrary then
        pcall(function()
            local e=EnumLibrary:ToEnum(skinName); if e then d.Enum=e; d.ObjectID=e end
        end)
    end
    _cosmeticCache[skinName]=d; return d
end

local function buildWrapData(n)
    local d=buildCosmeticData(n); if not d then return nil end
    local w={}; for k,v in pairs(d) do w[k]=v end; w.Type="Wrap"; return w
end

local function getLobbyWrap(wn)
    local lc=lobbyCosmetics[wn]; return lc and lc.Wrap or nil
end

local function applyEquippedSkin(wType,skinName)
    if skinName=="Default" or skinName==nil then 
        EquippedSkins[wType]=nil
    else 
        EquippedSkins[wType]=skinName
        _cosmeticCache[skinName]=nil 
    end
    _wdCache = {} -- Clear cache so new models render properly
    MasterData.Profiles[MasterData.CurrentProfile] = EquippedSkins
    saveMasterData()
end

-- ── Hooks Injection ───────────────────────────────────────────────────
local function _applyHooks()
    if _hooksApplied then return end; _hooksApplied=true
    if CosmeticLibrary then
        CosmeticLibrary.OwnsCosmeticNormally     = function() return true end
        CosmeticLibrary.OwnsCosmeticUniversally  = function() return true end
        CosmeticLibrary.OwnsCosmeticForSomething = function() return true end
        CosmeticLibrary.OwnsCosmeticForWeapon    = function() return true end
        local _o=CosmeticLibrary.OwnsCosmetic
        if _o then
            CosmeticLibrary.OwnsCosmetic=function(self,inv,name,weapon)
                if name and type(name)=="string" and name:find("MISSING_",1,true) then return _o(self,inv,name,weapon) end
                return true
            end
        end
    end
    if ClientItem and ClientItem._CreateViewModel then
        local _o=ClientItem._CreateViewModel
        ClientItem._CreateViewModel=function(self,vmRef)
            if not self.ClientFighter or self.ClientFighter.Player ~= LocalPlayer then 
                return _o(self,vmRef) 
            end
            
            local wName=self.Name
            _constructingWeapon=wName
            
            local sn=EquippedSkins[wName]
            if sn and sn~="Default" and vmRef then
                pcall(function()
                    local cd=buildCosmeticData(sn); if not cd then return end
                    local dk=self:ToEnum("Data"); local sk=self:ToEnum("Skin"); local nk=self:ToEnum("Name")
                    if vmRef[dk] then vmRef[dk][sk]=cd; if nk then vmRef[dk][nk]=sn end
                    elseif vmRef.Data then vmRef.Data.Skin=cd; vmRef.Data.Name=sn end
                end)
            end
            
            local r=_o(self,vmRef)
            _constructingWeapon=nil
            return r
        end
    end
    if ClientViewModelModule then
        if ClientViewModelModule.GetWrap then
            local _o=ClientViewModelModule.GetWrap
            ClientViewModelModule.GetWrap=function(self)
                local wn=self.ClientItem and self.ClientItem.Name
                local wp=self.ClientItem and self.ClientItem.ClientFighter and self.ClientItem.ClientFighter.Player
                if wn and wp==LocalPlayer then
                    local wn2=EquippedSkins[wn.."_wrap"]
                    if wn2 then local wd=buildWrapData(wn2); if wd then return wd end end
                    local lw=getLobbyWrap(wn); if lw then return lw end
                end
                return _o and _o(self) or nil
            end
        end
        local _o=ClientViewModelModule.new
        if _o then
            ClientViewModelModule.new=function(rd,ci)
                local wp=ci and ci.ClientFighter and ci.ClientFighter.Player
                if not wp or wp~=LocalPlayer then return _o(rd,ci) end
                
                local wn=_constructingWeapon or (ci and ci.Name)
                if wn then
                    pcall(function()
                        if not ReplicatedClass then return end
                        local RC_D=ReplicatedClass:ToEnum("Data"); local RC_S=ReplicatedClass:ToEnum("Skin")
                        if not RC_D or not RC_S then return end
                        if type(rd)~="table" then return end
                        rd[RC_D]=rd[RC_D] or {}
                        local sn=EquippedSkins[wn]
                        if sn and sn~="Default" then
                            local cd=buildCosmeticData(sn)
                            if cd then rd[RC_D][RC_S]=cd; local RC_N=ReplicatedClass:ToEnum("Name"); if RC_N then rd[RC_D][RC_N]=sn end end
                        end
                        local RC_W=ReplicatedClass:ToEnum("Wrap")
                        if RC_W then
                            local wn2=EquippedSkins[wn.."_wrap"]
                            local wrapData=wn2 and buildWrapData(wn2) or getLobbyWrap(wn)
                            if wrapData then rd[RC_D][RC_W]=wrapData end
                        end
                    end)
                end
                local vm=_o(rd,ci)
                if vm and vm._UpdateWrap and wp==LocalPlayer then
                    if _wrapDebounces[vm] then task.cancel(_wrapDebounces[vm]) end
                    _wrapDebounces[vm]=task.delay(0.15,function()
                        _wrapDebounces[vm]=nil
                        pcall(function() if not vm._destroyed then vm:_UpdateWrap() end end)
                    end)
                end
                return vm
            end
        end
    end
    if DataController then
        local _og=DataController.Get
        local _inv=setmetatable({},{__index=function() return true end,__newindex=function() end,__len=function() return 0 end,__pairs=function() return next,{},nil end,__ipairs=function() return next,{},nil end})
        DataController.Get=function(self,k) if k=="CosmeticInventory" then return _inv end; return _og(self,k) end
        
        local _ogWD=DataController.GetWeaponData
        DataController.GetWeaponData=function(self,wn)
            local ok,data=pcall(_ogWD,self,wn); if not ok or data==nil then return data end
            
            local sn=EquippedSkins[wn]
            local wn2=EquippedSkins[wn.."_wrap"]
            local lw=getLobbyWrap(wn)
            
            local hs=sn and sn~="Default"
            local hw=wn2 or lw
            if not hs and not hw then return data end
            
            -- Memory leak fix: Deep cache to prevent thousands of table clones per second
            local cacheKey = wn .. "|" .. tostring(sn) .. "|" .. tostring(wn2) .. "|" .. tostring(lw and lw.Name)
            if _wdCache[cacheKey] then return _wdCache[cacheKey] end
            
            local c = table.clone(data) -- Fast C-level clone instead of pairs loop
            if hs then local cd=buildCosmeticData(sn); if cd then c.Skin=cd end end
            if wn2 then local wd=buildWrapData(wn2); if wd then c.Wrap=wd end elseif lw then c.Wrap=lw end
            
            _wdCache[cacheKey] = c
            return c
        end
    end
end

