-- COSMETIC DATA BUILDER
local _cosmeticCache = {}
local _cosmeticLookup = nil

local function _ensureLookup()
    if _cosmeticLookup or not CosmeticLibrary or not CosmeticLibrary.Cosmetics then return end
    _cosmeticLookup = {}
    for k in pairs(CosmeticLibrary.Cosmetics) do
        if type(k) == "string" then
            _cosmeticLookup[k:lower()] = k
        end
    end
end

local function buildCosmeticData(skinName)
    if _cosmeticCache[skinName] then return _cosmeticCache[skinName] end
    if not CosmeticLibrary or not CosmeticLibrary.Cosmetics then return nil end
    _ensureLookup()
    local key = CosmeticLibrary.Cosmetics[skinName] and skinName
        or (_cosmeticLookup and _cosmeticLookup[skinName:lower()])
    local base = key and CosmeticLibrary.Cosmetics[key]
    if not base then return nil end
    -- Flat safe table only — full copies break weapon-specific inits (e.g. BaseRevolver
    -- ReloadBullets WaitForChild) causing camera lock and loadout corruption.
    local data = {
        Name                = skinName,
        Type                = "Skin",
        ItemName            = base.ItemName,
        Rarity              = base.Rarity,
        Image               = base.Image,
        ImageHighResolution = base.ImageHighResolution,
        ImageScale          = base.ImageScale,
        Description         = base.Description,
        Seed                = math.random(1, 1000000),
    }
    if EnumLibrary then
        pcall(function()
            local enumId = EnumLibrary:ToEnum(skinName)
            if enumId then data.Enum = enumId; data.ObjectID = enumId end
        end)
    end
    _cosmeticCache[skinName] = data
    return data
end

local function _applyHooks()
    if _hooksApplied then return end
    _hooksApplied = true

    if CosmeticLibrary then
        CosmeticLibrary.OwnsCosmeticNormally     = function() return true end
        CosmeticLibrary.OwnsCosmeticUniversally  = function() return true end
        CosmeticLibrary.OwnsCosmeticForSomething = function() return true end
        CosmeticLibrary.OwnsCosmeticForWeapon    = function() return true end
        local _origOwns = CosmeticLibrary.OwnsCosmetic
        if _origOwns then
            CosmeticLibrary.OwnsCosmetic = function(self, inv, name, weapon)
                if name and type(name)=="string" and name:find("MISSING_") then
                    return _origOwns(self, inv, name, weapon)
                end
                return true
            end
        end
    end

    if ClientItem and ClientItem._CreateViewModel then
        local _origCreate = ClientItem._CreateViewModel
        ClientItem._CreateViewModel = function(self, viewmodelRef)
            local wName   = self.Name
            local wPlayer = self.ClientFighter and self.ClientFighter.Player
            _constructingWeapon = (wPlayer == LocalPlayer) and wName or nil
            if wPlayer == LocalPlayer then
                local skinName = EquippedSkins[wName]
                if skinName and skinName ~= "Default" and viewmodelRef then
                    pcall(function()
                        local cosData = buildCosmeticData(skinName)
                        if not cosData then return end
                        local dk = self:ToEnum("Data")
                        local sk = self:ToEnum("Skin")
                        local nk = self:ToEnum("Name")
                        if viewmodelRef[dk] then
                            viewmodelRef[dk][sk] = cosData
                            if nk and not SKIP_RC_NAME[skinName] then
                                viewmodelRef[dk][nk] = skinName
                            end
                        elseif viewmodelRef.Data then
                            viewmodelRef.Data.Skin = cosData
                            if not SKIP_RC_NAME[skinName] then
                                viewmodelRef.Data.Name = skinName
                            end
                        end
                    end)
                end
            end
            local result = _origCreate(self, viewmodelRef)
            _constructingWeapon = nil
            return result
        end
    end

    if ClientViewModelModule then
        -- Hook GetWrap — returns our wrap override if one is equipped
        if ClientViewModelModule.GetWrap then
            local _origGetWrap = ClientViewModelModule.GetWrap
            ClientViewModelModule.GetWrap = function(self)
                local weaponName   = self.ClientItem and self.ClientItem.Name
                local weaponPlayer = self.ClientItem and self.ClientItem.ClientFighter
                                     and self.ClientItem.ClientFighter.Player
                if weaponName and weaponPlayer == LocalPlayer then
                    local wrapName = EquippedSkins[weaponName.."_wrap"]
                    if wrapName then
                        local wrapData = buildCosmeticData(wrapName)
                        if wrapData then return wrapData end
                    end
                end
                return _origGetWrap(self)
            end
        end

        local _origNew = ClientViewModelModule.new
        ClientViewModelModule.new = function(replicatedData, clientItem)
            local wPlayer = clientItem and clientItem.ClientFighter and clientItem.ClientFighter.Player
            local wName   = _constructingWeapon or (clientItem and clientItem.Name)
            if wPlayer == LocalPlayer and wName then
                pcall(function()
                    if not ReplicatedClass then return end
                    local RC_DATA = ReplicatedClass:ToEnum("Data")
                    local RC_SKIN = ReplicatedClass:ToEnum("Skin")
                    if not RC_DATA or not RC_SKIN then return end
                    replicatedData[RC_DATA] = replicatedData[RC_DATA] or {}

                    -- Inject skin
                    local skinName = EquippedSkins[wName]
                    if skinName and skinName ~= "Default" then
                        local cosData = buildCosmeticData(skinName)
                        if cosData then
                            replicatedData[RC_DATA][RC_SKIN] = cosData
                            -- Only set RC_NAME for registered skins
                            if not SKIP_RC_NAME[skinName] and cosData.Enum then
                                local RC_NAME = ReplicatedClass:ToEnum("Name")
                                if RC_NAME then replicatedData[RC_DATA][RC_NAME] = skinName end
                            end
                        end
                    end

                    -- Inject wrap
                    local wrapName = EquippedSkins[wName.."_wrap"]
                    if wrapName then
                        local wrapData = buildCosmeticData(wrapName)
                        local RC_WRAP  = ReplicatedClass:ToEnum("Wrap")
                        if wrapData and RC_WRAP then
                            replicatedData[RC_DATA][RC_WRAP] = wrapData
                        end
                    end
                end)
            end
            local vm = _origNew(replicatedData, clientItem)
            if vm and vm._UpdateWrap then
                task.defer(function()
                    pcall(function() vm:_UpdateWrap() end)
                    task.wait(0.1)
                    pcall(function()
                        if not vm._destroyed then vm:_UpdateWrap() end
                    end)
                end)
            end
            return vm
        end
    end

    print("[Rivals SC v1.1] Hooks applied")
end

