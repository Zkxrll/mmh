local CosmeticLibrary, ItemLibrary, ReplicatedClass, DataController
local ClientItem, ClientViewModelModule, EnumLibrary
local _constructingWeapon = nil
local _hooksApplied = false
local _viewingProfile = nil
local _cosmeticCache = {}
local _cosmeticLookup = nil

local function _ensureLookup()
    if _cosmeticLookup or not CosmeticLibrary or not CosmeticLibrary.Cosmetics then return end
    _cosmeticLookup = {}
    for k in pairs(CosmeticLibrary.Cosmetics) do
        if type(k) == "string" then _cosmeticLookup[k:lower()] = k end
    end
end

local function buildCosmeticData(skinName)
    if _cosmeticCache[skinName] then return _cosmeticCache[skinName] end
    if not CosmeticLibrary or not CosmeticLibrary.Cosmetics then return nil end
    _ensureLookup()
    local key = CosmeticLibrary.Cosmetics[skinName] and skinName
        or (_cosmeticLookup and _cosmeticLookup[skinName:lower()])
    local base = key and CosmeticLibrary.Cosmetics[key]
    if not base then return nil end
    local data = {
        Name=skinName, Type="Skin", ItemName=base.ItemName, Rarity=base.Rarity,
        Image=base.Image, ImageHighResolution=base.ImageHighResolution,
        ImageScale=base.ImageScale, Description=base.Description,
        Seed=math.random(1,1000000),
    }
    if EnumLibrary then
        pcall(function()
            local enumId = EnumLibrary:ToEnum(skinName)
            if enumId then data.Enum=enumId; data.ObjectID=enumId end
        end)
    end
    _cosmeticCache[skinName] = data
    return data
end

local function cloneCosmetic(name, cosmeticType)
    if not CosmeticLibrary or not CosmeticLibrary.Cosmetics then return nil end
    local base = CosmeticLibrary.Cosmetics[name]
    if not base then return nil end
    local data = {}
    for k,v in pairs(base) do data[k]=v end
    data.Name=name; data.Type=data.Type or cosmeticType; data.Seed=math.random(1,1000000)
    if EnumLibrary then
        pcall(function()
            local enumId=EnumLibrary:ToEnum(name)
            if enumId then data.Enum=enumId; data.ObjectID=enumId end
        end)
    end
    return data
end

-- ── Hooks ─────────────────────────────────────────────────────────────────────
local function _applyHooks()
    if _hooksApplied then return end
    _hooksApplied = true

    if CosmeticLibrary then
        CosmeticLibrary.OwnsCosmeticNormally     = function() return true end
        CosmeticLibrary.OwnsCosmeticUniversally  = function() return true end
        CosmeticLibrary.OwnsCosmeticForSomething = function() return true end
        CosmeticLibrary.OwnsCosmeticForWeapon    = function() return true end
        local _origOwns = CosmeticLibrary.OwnsCosmetic
        if _origOwns then
            CosmeticLibrary.OwnsCosmetic = function(self, inv, name, weapon)
                if name and type(name)=="string" and name:find("MISSING_") then
                    return _origOwns(self, inv, name, weapon)
                end
                return true
            end
        end
    end

    if ClientItem and ClientItem._CreateViewModel then
        local _origCreate = ClientItem._CreateViewModel
        ClientItem._CreateViewModel = function(self, viewmodelRef)
            local wName   = self.Name
            local wPlayer = self.ClientFighter and self.ClientFighter.Player
            _constructingWeapon = (wPlayer==LocalPlayer) and wName or nil
            if wPlayer==LocalPlayer then
                local skinName = EquippedSkins[wName]
                if skinName and skinName~="Default" and viewmodelRef then
                    pcall(function()
                        local cosData=buildCosmeticData(skinName)
                        if not cosData then return end
                        local dk=self:ToEnum("Data"); local sk=self:ToEnum("Skin"); local nk=self:ToEnum("Name")
                        if viewmodelRef[dk] then
                            viewmodelRef[dk][sk]=cosData
                            if nk then viewmodelRef[dk][nk]=skinName end
                        elseif viewmodelRef.Data then
                            viewmodelRef.Data.Skin=cosData; viewmodelRef.Data.Name=skinName
                        end
                    end)
                end
            end
            local result=_origCreate(self, viewmodelRef)
            _constructingWeapon=nil
            return result
        end
    end

    if ClientViewModelModule then
        if ClientViewModelModule.GetWrap then
            local _origGetWrap = ClientViewModelModule.GetWrap
            ClientViewModelModule.GetWrap = function(self)
                local weaponName   = self.ClientItem and self.ClientItem.Name
                local weaponPlayer = self.ClientItem and self.ClientItem.ClientFighter and self.ClientItem.ClientFighter.Player
                if weaponName and weaponPlayer==LocalPlayer then
                    local wrapName=EquippedSkins[weaponName.."_wrap"]
                    if wrapName then
                        local wrapData=buildCosmeticData(wrapName)
                        if wrapData then return wrapData end
                    end
                    local lc=lobbyCosmetics[weaponName]
                    if lc and lc.Wrap then return lc.Wrap end
                end
                return _origGetWrap(self)
            end
        end

        local _origNew = ClientViewModelModule.new
        ClientViewModelModule.new = function(replicatedData, clientItem)
            local wPlayer=clientItem and clientItem.ClientFighter and clientItem.ClientFighter.Player

            -- Skip entirely for every other player — this is the key shooting fix
            if wPlayer ~= LocalPlayer then
                return _origNew(replicatedData, clientItem)
            end

            local wName=_constructingWeapon or (clientItem and clientItem.Name)
            if wName then
                pcall(function()
                    if not ReplicatedClass then return end
                    local RC_DATA=ReplicatedClass:ToEnum("Data"); local RC_SKIN=ReplicatedClass:ToEnum("Skin")
                    if not RC_DATA or not RC_SKIN then return end
                    local skinName=EquippedSkins[wName]; local wrapName=EquippedSkins[wName.."_wrap"]
                    local lobbyWrap=lobbyCosmetics[wName] and lobbyCosmetics[wName].Wrap
                    local hasSkin=skinName and skinName~="Default"; local hasWrap=wrapName or lobbyWrap
                    if not hasSkin and not hasWrap then return end
                    replicatedData[RC_DATA]=replicatedData[RC_DATA] or {}
                    if hasSkin then
                        local cosData=buildCosmeticData(skinName)
                        if cosData then
                            replicatedData[RC_DATA][RC_SKIN]=cosData
                            if cosData.Enum then
                                local RC_NAME=ReplicatedClass:ToEnum("Name")
                                if RC_NAME then replicatedData[RC_DATA][RC_NAME]=skinName end
                            end
                        end
                    end
                    local RC_WRAP=ReplicatedClass:ToEnum("Wrap")
                    if RC_WRAP then
                        if wrapName then
                            local wrapData=buildCosmeticData(wrapName)
                            if wrapData then replicatedData[RC_DATA][RC_WRAP]=wrapData end
                        elseif lobbyWrap then
                            replicatedData[RC_DATA][RC_WRAP]=lobbyWrap
                        end
                    end
                end)
            end
            local vm=_origNew(replicatedData, clientItem)
            if vm and vm._UpdateWrap then
                task.defer(function()
                    pcall(function() vm:_UpdateWrap() end)
                    task.wait(0.1)
                    pcall(function() if not vm._destroyed then vm:_UpdateWrap() end end)
                end)
            end
            return vm
        end
    end
    print("[Rivals SC v1.1] Hooks applied")
end

-- ── FIX 1: hookfunction on specific remote instead of hookmetamethod on game ──
-- hookmetamethod(game, "__namecall") fires for EVERY namecall from every player
-- in the server. With 20 players that is hundreds of calls/sec causing the freeze.
-- hookfunction on the specific remote fires only when that one remote is called.
task.spawn(function()
    task.wait(1)
    -- FIX 2: WaitForChild so we don't get nil in public servers where
    -- instances haven't replicated yet when the script starts
    local Remotes     = ReplicatedStorage:WaitForChild("Remotes", 10)
    if not Remotes then return end
    local DataRemotes = Remotes:WaitForChild("Data", 10)
    if not DataRemotes then return end
    local EquipRemote = DataRemotes:WaitForChild("EquipCosmetic", 10)
    if not EquipRemote then return end

    local oldFS = hookfunction(EquipRemote.FireServer, function(self, weaponName, cosmeticType, cosmeticName)
        if weaponName and cosmeticType then
            if not cosmeticName or cosmeticName=="None" or cosmeticName=="" then
                if lobbyCosmetics[weaponName] then
                    lobbyCosmetics[weaponName][cosmeticType]=nil
                    if not next(lobbyCosmetics[weaponName]) then lobbyCosmetics[weaponName]=nil end
                end
            else
                local cloned=cloneCosmetic(cosmeticName, cosmeticType)
                if cloned then
                    lobbyCosmetics[weaponName]=lobbyCosmetics[weaponName] or {}
                    lobbyCosmetics[weaponName][cosmeticType]=cloned
                end
            end
        end
        return oldFS(self, weaponName, cosmeticType, cosmeticName)
    end)
    print("[Rivals SC v1.1] EquipCosmetic hook active")
end)

-- ── FIX 2: WaitForChild (with timeouts) for ALL module paths ─────────────────
-- FindFirstChild returns nil immediately if the child hasn't replicated yet.
-- In public servers that can be several seconds. Every require below it silently
-- fails and no hooks ever install, so skins never show.
task.spawn(function()
    local Mods   = ReplicatedStorage:WaitForChild("Modules", 10)
    if not Mods   then print("[SC] Modules timeout"); return end
    local PSMods = PlayerScripts:WaitForChild("Modules", 10)
    if not PSMods then print("[SC] PSMods timeout"); return end
    local Ctrls  = PlayerScripts:FindFirstChild("Controllers")

    pcall(function() CosmeticLibrary=require(Mods.CosmeticLibrary) end);  task.wait()
    pcall(function() ItemLibrary=require(Mods.ItemLibrary) end);           task.wait()
    pcall(function() ReplicatedClass=require(Mods.ReplicatedClass) end);   task.wait()
    pcall(function() EnumLibrary=require(Mods.EnumLibrary) end);           task.wait()

    -- Use WaitForChild for every nested path — public servers need this
    local CIF = PSMods:WaitForChild("ClientReplicatedClasses", 10)
    if CIF then
        local CF = CIF:WaitForChild("ClientFighter", 10)
        if CF then
            local CI = CF:WaitForChild("ClientItem", 10)
            if CI then
                pcall(function() ClientItem=require(CI) end); task.wait()
                local CVM = CI:WaitForChild("ClientViewModel", 10)
                if CVM then
                    pcall(function() ClientViewModelModule=require(CVM) end); task.wait()
                end
            end
        end
    end

    pcall(function() if Ctrls then DataController=require(Ctrls.PlayerDataController) end end)

    if DataController then
        local _origGet=DataController.Get
        local _inventoryProxy=setmetatable({},{__index=function() return true end})
        DataController.Get=function(self, key)
            if key=="CosmeticInventory" then return _inventoryProxy end
            return _origGet(self, key)
        end
        local _origGetWeaponData=DataController.GetWeaponData
        DataController.GetWeaponData=function(self, weaponName)
            local data=_origGetWeaponData(self, weaponName)
            if not data then return nil end
            local skinName=EquippedSkins[weaponName]
            if skinName and skinName~="Default" then
                local cosData=buildCosmeticData(skinName)
                if cosData then data.Skin=cosData end
            end
            local wrapName=EquippedSkins[weaponName.."_wrap"]
            if wrapName then
                local wrapData=buildCosmeticData(wrapName)
                if wrapData then data.Wrap=wrapData end
            end
            if not wrapName then
                local lc=lobbyCosmetics[weaponName]
                if lc and lc.Wrap then data.Wrap=lc.Wrap end
            end
            return data
        end
    end

    if ItemLibrary and ItemLibrary.GetViewModelImageFromWeaponData then
        local _origImg=ItemLibrary.GetViewModelImageFromWeaponData
        ItemLibrary.GetViewModelImageFromWeaponData=function(self, weaponData, highRes)
            if weaponData then
                local wn=weaponData.Name
                local skinName=EquippedSkins[wn]
                local showSkin=skinName and skinName~="Default" and (
                    (weaponData.Skin and weaponData.Skin.Name==skinName) or (_viewingProfile==LocalPlayer)
                )
                if showSkin then
                    local info=self.ViewModels and self.ViewModels[skinName]
                    if info then return info[highRes and "ImageHighResolution" or "Image"] or info.Image end
                end
            end
            return _origImg(self, weaponData, highRes)
        end
    end

    pcall(function()
        local PagesFolder = PSMods:FindFirstChild("Pages")
        if not PagesFolder then return end
        local ViewProfile = require(PagesFolder.ViewProfile)
        if ViewProfile and ViewProfile.Fetch then
            local orig=ViewProfile.Fetch
            ViewProfile.Fetch=function(self, targetPlayer)
                _viewingProfile=targetPlayer
                return orig(self, targetPlayer)
            end
        end
    end)

    _applyHooks()
    print("[Rivals SC v1.1] Ready — CL="..tostring(CosmeticLibrary~=nil)
        .." IL="..tostring(ItemLibrary~=nil)
        .." RC="..tostring(ReplicatedClass~=nil)
        .." EL="..tostring(EnumLibrary~=nil)
        .." DC="..tostring(DataController~=nil))
end)

-- ── Thumbnail cache ───────────────────────────────────────────────────────────
local _thumbCache = {}
local function getThumbnail(name)
    if _thumbCache[name]~=nil then return _thumbCache[name] end
    local img=""
    local function tryFields(d)
        if not d then return end
        local v=d.ImageHighResolution or d.Image or d.Thumbnail
        if v and v~="" then img=v end
    end
    pcall(function() if ItemLibrary and ItemLibrary.ViewModels then tryFields(ItemLibrary.ViewModels[name]) end end)
    if img=="" then pcall(function() tryFields(buildCosmeticData(name)) end) end
    _thumbCache[name]=img
    return img
end

local function applyEquippedSkin(weaponType, skinName)
    if skinName=="Default" or skinName==nil then
        EquippedSkins[weaponType]=nil
    else
        EquippedSkins[weaponType]=skinName
        _cosmeticCache[skinName]=nil
    end
    saveData(EquippedSkins, State.keybind)
end

