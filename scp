local SelectedWeapon = nil
local SelectedSkin   = nil
local SkinCards      = {}

local function rebuildSummary()
    for _,c in ipairs(SummaryScroll:GetChildren()) do
        if not c:IsA("UIListLayout") then c:Destroy() end
    end
    local order=1; local any=false
    for w,s in pairs(EquippedSkins) do
        if s and s~="Default" then
            any=true
            local row=inst("Frame",{Size=UDim2.new(1,0,0,20),BackgroundColor3=T.CARD,
                BorderSizePixel=0,LayoutOrder=order},SummaryScroll)
            corner(row,4)
            inst("UIPadding",{PaddingLeft=UDim.new(0,6),PaddingRight=UDim.new(0,5)},row)
            inst("TextLabel",{Size=UDim2.new(0.46,0,1,0),BackgroundTransparency=1,
                Text=w,Font=Enum.Font.GothamSemibold,TextSize=9,
                TextColor3=T.SEC,TextXAlignment=Enum.TextXAlignment.Left,
                TextTruncate=Enum.TextTruncate.AtEnd},row)
            inst("TextLabel",{Size=UDim2.new(0.54,0,1,0),Position=UDim2.new(0.46,0,0,0),
                BackgroundTransparency=1,Text=s,Font=Enum.Font.GothamSemibold,TextSize=9,
                TextColor3=getRarityColor(s),TextXAlignment=Enum.TextXAlignment.Right,
                TextTruncate=Enum.TextTruncate.AtEnd},row)
            order+=1
        end
    end
    if not any then
        inst("TextLabel",{Size=UDim2.new(1,0,0,20),BackgroundTransparency=1,
            Text="None active",Font=Enum.Font.Gotham,TextSize=10,
            TextColor3=T.MUT,TextXAlignment=Enum.TextXAlignment.Left,LayoutOrder=1},SummaryScroll)
    end
end

local function selectCard(skinName, thumb)
    SelectedSkin=skinName
    PreviewImg.Image=thumb or ""
    PreviewNone.Visible=(not thumb or thumb=="")
    PreviewSkinName.Text=skinName
    PreviewWeaponLabel.Text=SelectedWeapon or ""
    local d=buildCosmeticData(skinName)
    if d and d.Rarity then
        RarityBadge.Text=d.Rarity
        RarityBadge.TextColor3=getRarityColor(skinName)
    else
        RarityBadge.Text=""
    end
    EquipBtn.Text="Equip Skin"
    EquipBtn.BackgroundColor3=T.ACCENT
    for sn,card in pairs(SkinCards) do
        local isEquipped=SelectedWeapon and EquippedSkins[SelectedWeapon]==sn
        if sn==skinName then
            tw(card,{BackgroundColor3=T.SEL})
            local ring=card:FindFirstChild("_ring"); if ring then ring.Visible=true end
        elseif isEquipped then
            tw(card,{BackgroundColor3=T.CARDSEL})
            local ring=card:FindFirstChild("_ring"); if ring then ring.Visible=false end
        else
            tw(card,{BackgroundColor3=T.CARD})
            local ring=card:FindFirstChild("_ring"); if ring then ring.Visible=false end
        end
    end
end

local function buildSkinGrid(weaponName)
    for _,c in ipairs(SkinGrid:GetChildren()) do
        if c:IsA("ImageButton") or c:IsA("Frame") then c:Destroy() end
    end
    SkinCards={}; SelectedSkin=nil
    MidTitle.Text=weaponName:upper()
    local skins=SkinLists[weaponName] or {}
    local equipped=EquippedSkins[weaponName]
    for i,skinName in ipairs(skins) do
        local isEquipped=(equipped==skinName) or (skinName=="Default" and (not equipped or equipped=="Default"))
        local thumb=getThumbnail(skinName)
        local card=inst("ImageButton",{
            Size=UDim2.new(0,CARD_W+2,0,CARD_H+2),
            BackgroundColor3=isEquipped and T.CARDSEL or T.CARD,
            BorderSizePixel=0,Image="",LayoutOrder=i},SkinGrid)
        corner(card,6); stroke(card,isEquipped and T.SELBRD or T.BORDER,1)
        local imgH = math.floor(CARD_H*0.6)
        local imgFrame=inst("Frame",{
            Size=UDim2.new(1,-8,0,imgH),Position=UDim2.new(0,4,0,4),
            BackgroundColor3=T.BG,BorderSizePixel=0},card); corner(imgFrame,5)
        inst("ImageLabel",{
            Size=UDim2.new(0.88,0,0.88,0),Position=UDim2.new(0.06,0,0.06,0),
            BackgroundTransparency=1,Image=thumb,ScaleType=Enum.ScaleType.Fit,BorderSizePixel=0},imgFrame)
        if not thumb or thumb=="" then
            inst("TextLabel",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,
                Text="?",Font=Enum.Font.GothamBold,TextSize=20,
                TextColor3=T.MUT,TextXAlignment=Enum.TextXAlignment.Center},imgFrame)
        end
        inst("TextLabel",{
            Size=UDim2.new(1,-4,0,CARD_H-imgH-4),Position=UDim2.new(0,2,0,imgH+4),
            BackgroundTransparency=1,Text=skinName,
            Font=Enum.Font.GothamSemibold,TextSize=8,
            TextColor3=T.PRI,TextXAlignment=Enum.TextXAlignment.Center,TextWrapped=true},card)
        if isEquipped then
            local badge=inst("TextLabel",{
                Size=UDim2.new(0,44,0,12),Position=UDim2.new(0,3,0,3),
                BackgroundColor3=T.GREEN,Text="EQUIPPED",
                Font=Enum.Font.GothamBold,TextSize=6,
                TextColor3=Color3.fromRGB(255,255,255),BorderSizePixel=0},card); corner(badge,3)
        end
        if skinName~="Default" then
            local rc=getRarityColor(skinName)
            local rdot=inst("Frame",{
                Size=UDim2.new(0,5,0,5),Position=UDim2.new(1,-8,0,3),
                BackgroundColor3=rc,BorderSizePixel=0},card); corner(rdot,3)
        end
        local ring=inst("Frame",{
            Name="_ring",Size=UDim2.new(1,0,1,0),
            BackgroundTransparency=1,BorderSizePixel=0,Visible=false},card)
        stroke(ring,T.ACCENT,2); corner(ring,9)
        SkinCards[skinName]=card
        card.MouseEnter:Connect(function()
            if SelectedSkin~=skinName then tw(card,{BackgroundColor3=T.CARDH}) end
        end)
        card.MouseLeave:Connect(function()
            if SelectedSkin~=skinName then
                local eq=(EquippedSkins[weaponName]==skinName) or (skinName=="Default" and not EquippedSkins[weaponName])
                tw(card,{BackgroundColor3=eq and T.CARDSEL or T.CARD})
            end
        end)
        card.MouseButton1Click:Connect(function() selectCard(skinName,thumb) end)
    end
    local cur=EquippedSkins[weaponName]
    if cur and SkinCards[cur] then selectCard(cur,getThumbnail(cur))
    else selectCard("Default",getThumbnail("Default")) end
end

local function buildWeaponList(filter)
    filter=(filter or ""):lower()
    for _,c in ipairs(WList:GetChildren()) do
        if c:IsA("TextButton") then c:Destroy() end
    end
    local order=1
    for _,wn in ipairs(WeaponList) do
        if filter=="" or wn:lower():find(filter,1,true) then
            local isSel=(SelectedWeapon==wn)
            local hasApp=(EquippedSkins[wn] and EquippedSkins[wn]~="Default")
            local btn=inst("TextButton",{
                Size=UDim2.new(1,0,0,26),
                BackgroundColor3=isSel and T.SEL or T.CARD,
                BorderSizePixel=0,Text="",LayoutOrder=order},WList)
            corner(btn,5)
            if isSel then stroke(btn,T.SELBRD,1) end
            inst("TextLabel",{
                Size=UDim2.new(1,-16,1,0),Position=UDim2.new(0,8,0,0),
                BackgroundTransparency=1,Text=wn,
                Font=Enum.Font.GothamSemibold,TextSize=10,
                TextColor3=isSel and T.PRI or (hasApp and T.GREEN or T.SEC),
                TextXAlignment=Enum.TextXAlignment.Left,
                TextTruncate=Enum.TextTruncate.AtEnd},btn)
            if hasApp then
                local d=inst("Frame",{
                    Size=UDim2.new(0,4,0,4),Position=UDim2.new(1,-8,0.5,-2),
                    BackgroundColor3=T.GREEN,BorderSizePixel=0},btn); corner(d,2)
            end
            btn.MouseEnter:Connect(function() if not isSel then tw(btn,{BackgroundColor3=T.CARDH}) end end)
            btn.MouseLeave:Connect(function() if not isSel then tw(btn,{BackgroundColor3=isSel and T.SEL or T.CARD}) end end)
            btn.MouseButton1Click:Connect(function()
                SelectedWeapon=wn; buildSkinGrid(wn); buildWeaponList(WSearch.Text)
            end)
            order+=1
        end
    end
end
WSearch:GetPropertyChangedSignal("Text"):Connect(function() buildWeaponList(WSearch.Text) end)

